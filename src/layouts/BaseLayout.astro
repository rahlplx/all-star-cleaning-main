---
import BaseHead from '@/components/BaseHead.astro';
import TopBar from '@/components/TopBar.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import StickyBottomCTA from '@/components/StickyBottomCTA.astro';
import JsonLd from '@/components/JsonLd.astro';
import { getLocalBusinessSchema } from '@/seo';
import '@/styles/global.css';

interface Props {
  title: string; description: string; locale: 'en' | 'fr';
  canonicalUrl?: string; ogImage?: string;
  alternateUrls?: { locale: string; url: string }[]; noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, locale, canonicalUrl, ogImage, alternateUrls, noindex, schema } = Astro.props;
const siteUrl = 'https://allstarcleaning.ca';
const pageUrl = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const localBusinessSchema = getLocalBusinessSchema({ locale, url: `${siteUrl}/${locale}/` });
const allSchemas = schema ? [localBusinessSchema, ...(Array.isArray(schema) ? schema : [schema])] : [localBusinessSchema];
const themeColor = '#1e40af';
---
<!doctype html>
<html lang={locale} class="scroll-smooth antialiased">
  <head>
    <BaseHead title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage} locale={locale} alternateUrls={alternateUrls} noindex={noindex} />
    <JsonLd data={allSchemas} />
    <meta name="theme-color" content={themeColor} />
  </head>
  <body class="flex min-h-screen flex-col bg-background text-foreground antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-midnight-indigo focus:px-4 focus:py-2 focus:text-text-on-dark focus:shadow-lg">{locale === 'fr' ? 'Aller au contenu principal' : 'Skip to main content'}</a>
    <TopBar locale={locale} />
    <Header locale={locale} />
    <main id="main-content" class="flex-1 pb-20 md:pb-0"><slot /></main>
    <Footer locale={locale} />
    <StickyBottomCTA locale={locale} currentPath={Astro.url.pathname} />
  </body>
</html>
