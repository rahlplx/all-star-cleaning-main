---
import BaseLayout from './BaseLayout.astro';
import type { BreadcrumbItem } from '@/types';
interface Props {
  title: string; description: string; locale: 'en' | 'fr';
  breadcrumbs?: BreadcrumbItem[]; heroTitle?: string; heroSubtitle?: string;
  canonicalUrl?: string; ogImage?: string;
  alternateUrls?: { locale: string; url: string }[]; noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}
const { title, description, locale, breadcrumbs = [], heroTitle, heroSubtitle, canonicalUrl, ogImage, alternateUrls, noindex, schema } = Astro.props;
---
<BaseLayout title={title} description={description} locale={locale} canonicalUrl={canonicalUrl} ogImage={ogImage} alternateUrls={alternateUrls} noindex={noindex} schema={schema}>
  {breadcrumbs.length > 0 && (
    <nav aria-label={locale === 'fr' ? "Fil d'Ariane" : 'Breadcrumb'} class="border-b border-border bg-card">
      <div class="mx-auto max-w-7xl px-4 py-3">
        <ol class="flex items-center gap-2 text-sm text-muted-foreground">
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>}
              {i < breadcrumbs.length - 1 ? (
                <a href={crumb.href} class="transition-colors hover:text-midnight-indigo">{locale === 'fr' ? crumb.frLabel : crumb.label}</a>
              ) : (
                <span class="font-bold text-midnight-indigo" aria-current="page">{locale === 'fr' ? crumb.frLabel : crumb.label}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </nav>
  )}
  {heroTitle && (
    <section class="relative overflow-hidden brand-gradient border-b border-border/50 py-10 text-text-on-dark md:py-16 lg:py-24">
      <div class="relative z-10 mx-auto max-w-7xl px-4">
        <h1 class="slide-up font-heading font-bold tracking-tight text-[var(--text-display)] text-white">{heroTitle}</h1>
        {heroSubtitle && <p class="fade-in delay-2 mt-3 max-w-2xl text-base text-text-on-dark-muted sm:text-lg md:text-xl">{heroSubtitle}</p>}
      </div>
    </section>
  )}
  <main><slot /></main>
</BaseLayout>
