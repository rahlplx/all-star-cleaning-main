---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { getFounderSchema, getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import aboutData from '@/content/about.json';
import homepageData from '@/content/homepage.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const cms = aboutData;
const home = homepageData;

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'About', frLabel: 'À Propos', href: `/${locale}/about` },
];

const founderSchema = getFounderSchema(locale);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
---
<PageLayout
  title={isFr ? 'À Propos | All Star Cleaning Ottawa' : 'About | All Star Cleaning Ottawa'}
  description={isFr ? "Découvrez All Star Cleaning: votre partenaire de confiance pour le nettoyage extérieur à Ottawa." : "Learn about All Star Cleaning: your trusted partner for exterior cleaning in Ottawa."}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? 'À Propos' : 'About All Star Cleaning'}
  heroSubtitle={isFr ? "Votre partenaire de confiance pour le nettoyage extérieur à Ottawa" : 'Your trusted partner for exterior cleaning across Ottawa'}
  schema={[founderSchema, breadcrumbSchema]}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/about/` }]}
>
  <section class="py-8 sm:py-12">
    <div class="mx-auto max-w-5xl px-4">
      <div class="section-asymmetric items-start">
        <!-- Left column: Main content -->
        <div class="order-2 lg:order-1">
          <!-- Review Badge -->
          <div class="flex flex-wrap items-center gap-3">
            <div class="flex items-center gap-2 rounded-full bg-gold/10 px-4 py-2 border border-gold/20">
              <span class="text-gold-light text-sm" aria-label="5 out of 5 stars">★★★★★</span>
              <span class="text-sm font-bold text-navy">{home.googleRating}</span>
              <span class="text-xs text-muted-foreground">{isFr ? `${home.googleReviewCount} avis Google` : `${home.googleReviewCount} Google reviews`}</span>
            </div>
            <div class="flex items-center gap-2 rounded-full bg-teal/10 px-4 py-2 border border-teal/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-teal-text" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              <span class="text-sm font-semibold text-navy">{isFr ? 'Assuré & Cautionné' : 'Insured & Bonded'}</span>
            </div>
          </div>

          <div class="measure mt-8 space-y-6 text-muted-foreground leading-relaxed">
            <p class="fade-in delay-1">{isFr ? cms.storyParagraph1Fr : cms.storyParagraph1En}</p>

            <blockquote class="my-8 rounded-lg border border-teal-text/20 bg-teal/5 px-6 py-4">
              <p class="font-heading text-xl text-navy italic">{isFr ? cms.blockquoteFr : cms.blockquoteEn}</p>
              <footer class="mt-2 text-sm text-muted-foreground not-italic">{isFr ? 'Notre Garantie sans Tracas' : 'Our Hassle-Free Guarantee'}</footer>
            </blockquote>

            <p class="fade-in delay-1">{isFr ? cms.storyParagraph2Fr : cms.storyParagraph2En}</p>
            <p class="fade-in delay-1">{isFr ? cms.storyParagraph3Fr : cms.storyParagraph3En}</p>
          </div>

          <div class="mt-8 lg:hidden">
            <a href={`/${locale}/contact`} class="touch-target inline-flex items-center gap-2 rounded-lg uppercase tracking-wider bg-gold px-8 py-4 text-base font-bold text-navy transition-all hover:bg-gold-light hover:shadow-xl w-full justify-center">
              {t.cta.freeQuote}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
          <div class="mt-8 hidden lg:block">
            <a href={`/${locale}/contact`} class="inline-flex items-center gap-2 rounded-lg uppercase tracking-wider bg-gold px-8 py-4 text-lg font-semibold text-navy transition-all hover:bg-gold-light hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold touch-target">{t.cta.freeQuote}</a>
          </div>
        </div>

        <!-- Right column: Team image + stats + values -->
        <div class="order-1 lg:order-2 space-y-6">
          <div class="fade-in delay-1 overflow-hidden rounded-xl shadow-lg">
            <img
              src={cms.teamImage || '/images/team-at-work.jpg'}
              alt={isFr ? "L'équipe All Star Cleaning au travail" : 'All Star Cleaning team at work'}
              width="800"
              height="450"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>

          <div class="fade-in delay-2">
            <div class="rounded-xl border border-border bg-card p-5 text-center">
              <span class="text-4xl font-bold text-navy">{home.googleRating}</span>
              <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Note Google' : 'Google Rating'}</p>
            </div>
          </div>

          <div class="fade-in delay-2 rounded-xl bg-teal-text p-6 text-text-on-dark shadow-lg">
            <h2 class="font-heading text-2xl font-bold">{isFr ? 'Nos Valeurs' : 'Our Values'}</h2>
            <ul class="mt-4 space-y-3">
              {cms.values.map((value) => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-teal-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{isFr ? value.fr : value.en}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
