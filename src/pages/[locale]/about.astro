---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { getFounderSchema, getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import aboutData from '@/content/about.json';
import homepageData from '@/content/homepage.json';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const cms = aboutData;
const home = homepageData;

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'About', frLabel: 'À Propos', href: `/${locale}/about` },
];

const founderSchema = getFounderSchema(locale);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
---
<PageLayout
  title={isFr ? 'À Propos | All Star Cleaning Ottawa' : 'About | All Star Cleaning Ottawa'}
  description={isFr ? "Découvrez All Star Cleaning: votre partenaire de confiance pour le nettoyage extérieur à Ottawa." : "Learn about All Star Cleaning: your trusted partner for exterior cleaning in Ottawa."}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? 'À Propos' : 'About All Star Cleaning'}
  heroSubtitle={isFr ? "Votre partenaire de confiance pour le nettoyage extérieur à Ottawa" : 'Your trusted partner for exterior cleaning across Ottawa'}
  schema={[founderSchema, breadcrumbSchema]}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/about/` }]}
>
  <section class="py-8 sm:py-12">
    <div class="mx-auto max-w-5xl px-4">
      <div class="section-asymmetric items-start">
        <!-- Left column: Main content -->
        <div class="order-2 lg:order-1">
          <!-- Review Badge -->
          <div class="flex flex-wrap items-center gap-3">
            <a 
              href={siteSettings.googleUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center gap-2 rounded-full bg-royal-blue/10 px-4 py-2 border border-royal-blue/20 transition-all hover:bg-royal-blue/20 hover:scale-105 active:scale-95"
              aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c3.11 0 5.72-1.03 7.63-2.77l-3.57-2.77c-1.01.68-2.31 1.09-4.06 1.09-3.13 0-5.78-2.11-6.73-4.96H2.62v2.87C4.52 20.38 8.04 23 12 23z" fill="#34A853"/><path d="M5.27 13.59c-.24-.71-.38-1.47-.38-2.27 0-.79.14-1.55.38-2.26V6.19H2.62C1.81 7.82 1.35 9.66 1.35 11.62c0 1.96.46 3.8 1.27 5.43l2.65-2.07z" fill="#FBBC05"/><path d="M12 4.39c1.7 0 3.22.58 4.42 1.73l3.31-3.31C17.71 1.05 15.09 0 12 0 8.04 0 4.52 2.62 2.62 6.19l3.3 2.57C6.88 6.5 9.53 4.39 12 4.39z" fill="#EA4335"/></svg>
              <span class="text-royal-blue text-sm" aria-label="5 out of 5 stars">★★★★★</span>
              <span class="text-sm font-bold text-navy">{home.googleRating}</span>
              <span class="text-xs text-muted-foreground">{isFr ? `${home.googleReviewCount} avis Google` : `${home.googleReviewCount} Google reviews`}</span>
            </a>
            <div class="flex items-center gap-2 rounded-full bg-royal-blue/10 px-4 py-2 border border-royal-blue/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-royal-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              <span class="text-sm font-semibold text-navy">{isFr ? 'Assuré & Cautionné' : 'Insured & Bonded'}</span>
            </div>
          </div>

          <div class="measure mt-8 space-y-6 text-muted-foreground leading-relaxed">
            <p class="fade-in delay-1">{isFr ? cms.storyParagraph1Fr : cms.storyParagraph1En}</p>

            <blockquote class="my-8 rounded-lg border border-royal-blue/20 bg-royal-blue/5 px-6 py-5 shadow-sm">
              <p class="font-heading text-xl text-navy italic leading-relaxed">"{isFr ? cms.blockquoteFr : cms.blockquoteEn}"</p>
              <footer class="mt-3 flex items-center gap-2 text-sm font-bold uppercase tracking-wider text-royal-blue">
                <span class="h-px w-6 bg-royal-blue/30"></span>
                {isFr ? 'L\'Engagement All Star' : 'The All Star Commitment'}
              </footer>
            </blockquote>

            <p class="fade-in delay-1">{isFr ? cms.storyParagraph2Fr : cms.storyParagraph2En}</p>
            <p class="fade-in delay-1">{isFr ? cms.storyParagraph3Fr : cms.storyParagraph3En}</p>
          </div>

          <div class="mt-8 lg:hidden">
            <a href={`/${locale}/contact`} class="touch-target inline-flex items-center gap-2 rounded-lg uppercase tracking-wider bg-royal-blue px-8 py-4 text-base font-bold text-white transition-all hover:bg-royal-blue-dark hover:shadow-xl w-full justify-center">
              {t.cta.freeQuote}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
          <div class="mt-8 hidden lg:block">
            <a href={`/${locale}/contact`} class="inline-flex items-center gap-2 rounded-lg uppercase tracking-wider bg-royal-blue px-8 py-4 text-lg font-semibold text-white transition-all hover:bg-royal-blue-dark hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-royal-blue touch-target">{t.cta.freeQuote}</a>
          </div>
        </div>

        <!-- Right column: Team image + stats + values -->
        <div class="order-1 lg:order-2 space-y-6">
          <div class="fade-in delay-1 overflow-hidden rounded-xl shadow-lg">
            <img
              src={cms.teamImage || '/images/team-at-work.jpg'}
              alt={isFr ? "L'équipe All Star Cleaning au travail" : 'All Star Cleaning team at work'}
              width="800"
              height="450"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>

          <div class="fade-in delay-2">
            <a 
              href={siteSettings.googleUrl} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="block rounded-xl border border-border bg-card p-5 text-center transition-all hover:bg-royal-blue/5 hover:scale-105 active:scale-95"
              aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
            >
              <span class="text-4xl font-bold text-navy">{home.googleRating}</span>
              <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Note Google' : 'Google Rating'}</p>
            </a>
          </div>

          <div class="fade-in delay-2 rounded-xl bg-royal-blue p-6 text-white shadow-lg">
            <h2 class="font-heading text-2xl font-bold">{isFr ? 'Nos Valeurs' : 'Our Values'}</h2>
            <ul class="mt-4 space-y-3">
              {cms.values.map((value) => (
                <li class="flex items-start gap-3">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-white/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{isFr ? value.fr : value.en}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
