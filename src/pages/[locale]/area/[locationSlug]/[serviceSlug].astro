---
// Location + Service combo page — Astro v6
// Generates 5 services × 44 locations × 2 langs = 440 pages
import PageLayout from '@/layouts/PageLayout.astro';
import ServiceBadge from '@/components/ServiceBadge.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import GoogleReviewBadge from '@/components/GoogleReviewBadge.astro';
import SidebarCTA from '@/components/SidebarCTA.astro';
import { useTranslations } from '@/i18n/translations';
import { services } from '@/data/services';
import { locations } from '@/data/locations';
import { getLocationServiceSchema, getBreadcrumbSchema, getFAQSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return ['en', 'fr'].flatMap((locale) =>
    locations.flatMap((location) =>
      services.map((service) => ({
        params: { locale, locationSlug: location.slug, serviceSlug: service.slug },
        props: { service, location, locale: locale as 'en' | 'fr' },
      }))
    )
  );
}

const { service, location, locale } = Astro.props;
const isFr = locale === 'fr';
const t = useTranslations(locale);
const altLocale = isFr ? 'en' : 'fr';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Services', frLabel: 'Services', href: `/${locale}/services` },
  { label: service.name, frLabel: service.frName, href: `/${locale}/services/${service.slug}` },
  { label: location.name, frLabel: location.frName, href: `/${locale}/area/${location.slug}/${service.slug}` },
];

const locServiceSchema = getLocationServiceSchema(service, location, locale, `https://allstarcleaning.ca/${locale}/area/${location.slug}/${service.slug}`);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const faqSchema = service.faqs && service.faqs.length > 0 ? getFAQSchema(service.faqs, locale) : null;
const allSchemas = [locServiceSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];

const heroTitle = isFr
  ? `${service.frName} à ${location.frName}`
  : `${service.name} in ${location.name}`;
const heroSubtitle = isFr
  ? `${service.frDescription} Desservant ${location.frName} et les environs d'Ottawa.`
  : `${service.description} Serving ${location.name} and surrounding Ottawa areas.`;
const altSlug = service.slug;  // Both locales use EN slugs in URLs

const responseTimeText = service.slug === 'snow-removal'
  ? (isFr ? 'Sans engagement · Réponse sous 4h lors des tempêtes' : 'No obligation · Response within 4 hours during storms')
  : (isFr ? 'Sans engagement · Réponse sous 24h' : 'No obligation · 24hr response');
---

<PageLayout
  title={isFr ? `${service.frName} ${location.frName} Ottawa | All Star Cleaning` : `${service.name} ${location.name} Ottawa | All Star Cleaning`}
  description={isFr ? `${service.frName} professionnel à ${location.frName}, Ottawa. Devis gratuit: résidentiel et commercial.` : `Professional ${service.name.toLowerCase()} in ${location.name}, Ottawa. Free quote: residential & commercial.`}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={heroTitle}
  heroSubtitle={heroSubtitle}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/area/${location.slug}/${altSlug}/` }]}
  schema={allSchemas}
>
  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <!-- Review Badge -->
      <div class="mb-6 flex flex-wrap items-center gap-3">
        <GoogleReviewBadge locale={locale} variant="pill" />
          <div class="touch-target flex items-center gap-2 rounded-full bg-midnight-indigo/10 px-4 py-2 border border-midnight-indigo/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="text-sm font-semibold text-navy">{t.trust.insured}</span>
        </div>
      </div>

      <!-- Service Features -->
      <h2 class="font-heading heading-card font-bold text-midnight-indigo measure">
        {isFr ? `Ce que notre ${service.frName.toLowerCase()} à ${location.frName} comprend` : `What our ${service.name.toLowerCase()} in ${location.name} includes`}
      </h2>
      <ul class="mt-4 space-y-3">
        {(isFr ? service.frFeatures : service.features).map((feature) => (
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground">{feature}</span>
          </li>
        ))}
      </ul>

      <!-- Mobile-only inline CTA -->
      <div class="mt-6 lg:hidden">
        <a href={`/${locale}/contact?service=${service.slug}&area=${location.slug}`} class="touch-target inline-flex items-center gap-2 rounded-full uppercase tracking-wider bg-midnight-indigo px-6 py-4 text-base font-bold text-text-on-dark shadow-lg transition-colors duration-200 hover:bg-midnight-indigo-dark hover:shadow-xl focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 w-full justify-center">
          {isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <p class="mt-2 text-center text-sm text-muted-foreground">{responseTimeText}</p>
      </div>

      <!-- Area Context -->
      <div class="mt-8 rounded-xl border border-border bg-card p-6">
        <h2 class="font-heading heading-card font-bold text-midnight-indigo">
          {isFr ? `Service à ${location.frName}` : `Serving ${location.name}`}
        </h2>
        <p class="mt-2 measure text-muted-foreground leading-relaxed">
          {isFr
            ? `Nous sommes fiers de desservir ${location.frName} et les quartiers environnants de la région d'Ottawa. Notre équipe locale connaît bien les besoins uniques des propriétés dans cette zone ${location.area} d'Ottawa.`
            : `We proudly serve ${location.name} and surrounding neighbourhoods in the Ottawa region. Our local team understands the unique needs of properties in this ${location.area} Ottawa zone.`}
        </p>
        {location.neighbours.length > 0 && (
          <div class="mt-4">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">{isFr ? 'Quartiers avoisinants' : 'Nearby Areas'}</h3>
            <div class="mt-2 flex flex-wrap gap-2">
              {location.neighbours.map((neighbour) => {
                const loc = locations.find((l) => l.slug === neighbour);
                return loc ? (
                  <ServiceBadge label={isFr ? loc.frName : loc.name} href={`/${locale}/area/${loc.slug}/${service.slug}`} variant="teal" />
                ) : null;
              })}
            </div>
          </div>
        )}
      </div>

      <!-- Map for location -->
      <div class="mt-8 rounded-xl border border-border overflow-hidden">
        <iframe
          src={`https://www.google.com/maps?q=${location.coordinates.lat},${location.coordinates.lng}&z=13&output=embed`}
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={isFr ? `Carte de ${location.frName}` : `Map of ${location.name}`}
        ></iframe>
      </div>

      <!-- Other Services in this Area -->
      <div class="mt-8">
        <h2 class="font-heading heading-card font-bold text-midnight-indigo">
          {isFr ? `Autres services à ${location.frName}` : `Other services in ${location.name}`}
        </h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {services.filter((s) => s.slug !== service.slug).map((otherService, i) => (
            <a href={`/${locale}/area/${location.slug}/${otherService.slug}`} class={`group rounded-xl border border-border bg-card p-4 transition-colors duration-200 hover:border-midnight-indigo/30 focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 hover:shadow-md hover-lift ${i === 0 ? 'sm:col-span-2 border-midnight-indigo/20 bg-midnight-indigo/5' : ''}`}>
              <h3 class="font-medium text-navy group-hover:text-midnight-indigo">{isFr ? otherService.frName : otherService.name}</h3>
              <p class="mt-1 text-sm text-muted-foreground line-clamp-2">{isFr ? otherService.frDescription : otherService.description}</p>
            </a>
          ))}
        </div>
      </div>

      <!-- FAQ Section — driven by service.faqs data -->
      <FAQAccordion
        faqs={service.faqs}
        locale={locale}
        title={isFr ? `Questions fréquentes: ${service.frName} à ${location.frName}` : `Frequently asked questions: ${service.name} in ${location.name}`}
      />
    </div>

    <!-- Sidebar CTA -->
    <div class="lg:col-span-1">
      <SidebarCTA
        heading={isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}
        description={isFr ? service.frCta : service.cta}
        ctaText={isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}
        contactHref={`/${locale}/contact?service=${service.slug}&area=${location.slug}`}
        responseTimeText={responseTimeText}
        phoneLink={siteSettings.phoneLink}
        phone={siteSettings.phone}
      />
    </div>
  </div>
</PageLayout>
