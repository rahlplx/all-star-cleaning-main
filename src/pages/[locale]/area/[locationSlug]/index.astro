---
// Location hub page — lists all services available in a given location
// Generates 44 locations × 2 locales = 88 pages
import PageLayout from '@/layouts/PageLayout.astro';
import ServiceBadge from '@/components/ServiceBadge.astro';
import { services } from '@/data/services';
import { locations } from '@/data/locations';
import { getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';

export function getStaticPaths() {
  return ['en', 'fr'].flatMap((locale) =>
    locations.map((location) => ({
      params: { locale, locationSlug: location.slug },
      props: { location, locale: locale as 'en' | 'fr' },
    }))
  );
}

const { location, locale } = Astro.props;
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Areas', frLabel: 'Régions', href: `/${locale}/area/${location.slug}` },
  { label: location.name, frLabel: location.frName, href: `/${locale}/area/${location.slug}` },
];

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);

const heroTitle = isFr
  ? `Services de Nettoyage à ${location.frName}`
  : `Cleaning Services in ${location.name}`;
const heroSubtitle = isFr
  ? `Services professionnels de nettoyage extérieur à ${location.frName} et les environs. Vitres, gouttières, lavage sous pression, revêtement et déneigement.`
  : `Professional exterior cleaning services in ${location.name} and surrounding areas. Window, gutter, pressure washing, siding & snow removal.`;
---

<PageLayout
  title={isFr ? `Services de Nettoyage à ${location.frName} Ottawa | All Star Cleaning` : `Cleaning Services in ${location.name} Ottawa | All Star Cleaning`}
  description={isFr
    ? `Services de nettoyage extérieur professionnels à ${location.frName}, Ottawa. Vitres, gouttières, lavage sous pression, revêtement et déneigement. Devis gratuit.`
    : `Professional exterior cleaning services in ${location.name}, Ottawa. Window, gutter, pressure washing, siding cleaning & snow removal. Free quote.`}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={heroTitle}
  heroSubtitle={heroSubtitle}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/area/${location.slug}/` }]}
  schema={[breadcrumbSchema]}
>
  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <!-- Area Context -->
      <div class="mb-8 rounded-xl border border-border bg-card p-6">
        <h2 class="font-heading text-2xl font-bold text-navy">
          {isFr ? `Nettoyage Extérieur à ${location.frName}` : `Exterior Cleaning in ${location.name}`}
        </h2>
        <p class="mt-2 measure text-muted-foreground leading-relaxed">
          {isFr
            ? `Nous sommes fiers de desservir ${location.frName} et les quartiers environnants de la région d'Ottawa. Notre équipe locale connaît bien les besoins uniques des propriétés dans cette zone ${location.area} d'Ottawa. Appelez-nous au (613) 314-3300 pour un devis gratuit.`
            : `We proudly serve ${location.name} and surrounding neighbourhoods in the Ottawa region. Our local team understands the unique needs of properties in this ${location.area} Ottawa zone. Call us at (613) 314-3300 for a free quote.`}
        </p>
      </div>

      <!-- Map for location -->
      <div class="mb-8 rounded-xl border border-border overflow-hidden">
        <iframe
          src={`https://www.google.com/maps?q=${location.coordinates.lat},${location.coordinates.lng}&z=13&output=embed`}
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={isFr ? `Carte de ${location.frName}` : `Map of ${location.name}`}
        ></iframe>
      </div>

      <!-- All Services Grid -->
      <h2 class="font-heading text-2xl font-bold text-navy">
        {isFr ? 'Nos Services à' : 'Our Services in'} {isFr ? location.frName : location.name}
      </h2>
      <div class="mt-4 grid gap-4 sm:grid-cols-2">
        {services.map((service, i) => (
          <a
            href={`/${locale}/area/${location.slug}/${service.slug}`}
            class:list={[
              'group rounded-lg border border-border bg-card p-5 transition-all hover:border-teal-text/30 hover:shadow-md hover-lift',
              i === 0 ? 'sm:col-span-2 border-teal-text/20 bg-teal/5' : '',
            ]}
          >
            <h3 class="font-heading text-lg font-semibold text-navy group-hover:text-teal-text">
              {isFr ? service.frName : service.name}
            </h3>
            <p class="mt-2 text-sm text-muted-foreground line-clamp-2">
              {isFr ? service.frDescription : service.description}
            </p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-teal-text">
              {isFr ? 'En savoir plus' : 'Learn more'}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Neighbouring Areas -->
      {location.neighbours.length > 0 && (
        <div class="mt-10">
          <h2 class="font-heading text-2xl font-bold text-navy">
            {isFr ? 'Quartiers avoisinants' : 'Nearby Areas'}
          </h2>
          <div class="mt-4 flex flex-wrap gap-2">
            {location.neighbours.map((neighbour) => {
              const loc = locations.find((l) => l.slug === neighbour);
              return loc ? (
                <ServiceBadge label={isFr ? loc.frName : loc.name} href={`/${locale}/area/${loc.slug}`} variant="teal" />
              ) : null;
            })}
          </div>
        </div>
      )}
    </div>

    <!-- Sidebar CTA -->
    <div class="lg:col-span-1">
      <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto rounded-xl border border-border bg-card p-6">
        <h3 class="font-heading text-xl font-bold text-navy">{isFr ? 'Obtenez un Devis' : 'Get a Quote'}</h3>
        <p class="mt-2 text-sm text-muted-foreground">
          {isFr
            ? `Besoin de services de nettoyage à ${location.frName}? Contactez-nous pour un devis gratuit.`
            : `Need cleaning services in ${location.name}? Contact us for a free quote.`}
        </p>
        <a href={`/${locale}/contact?area=${location.slug}`} class="mt-4 block rounded-lg uppercase tracking-wider bg-gold px-6 py-4 text-center text-base font-bold text-navy shadow-lg transition-all hover:bg-gold-light hover:shadow-xl active:scale-[0.98] touch-target">
          {isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}
        </a>
        <p class="mt-2 text-center text-sm text-muted-foreground">{isFr ? 'Sans engagement · Réponse sous 24h' : 'No obligation · 24hr response'}</p>
        <div class="mt-4 border-t border-border pt-4 text-center text-sm text-muted-foreground">
          <a href="tel:+16133143300" class="inline-flex items-center gap-2 font-semibold text-teal-text hover:text-teal-dark touch-target">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (613) 314-3300
          </a>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
