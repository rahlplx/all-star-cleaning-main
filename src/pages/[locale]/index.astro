---
// Dynamic locale homepage — Astro v6
import BaseLayout from '@/layouts/BaseLayout.astro';
import { services } from '@/data/services';
import { useTranslations } from '@/i18n/translations';
import { getHowToSchema, getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import homepageData from '@/content/homepage.json';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}

const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const howtoSchema = getHowToSchema(locale);
const homeBreadcrumbSchema = getBreadcrumbSchema([
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
], locale);
const usps = [
  { icon: 'shield', title: t.usps.expertise.title, description: t.usps.expertise.description },
  { icon: 'sparkles', title: t.usps.equipment.title, description: t.usps.equipment.description },
  { icon: 'check-circle', title: t.usps.guarantee.title, description: t.usps.guarantee.description },
];


// CMS-managed content (editable via Keystatic at /keystatic)
const cms = homepageData;

const serviceObjectPosition: Record<string, string> = {
  'window-cleaning':  'object-center',
  'gutter-cleaning':  'object-[center_30%]',
  'pressure-washing': 'object-center',
  'siding-cleaning':  'object-center',
  'snow-removal':     'object-center',
};

const serviceBadgeMap: Record<string, { en: string; fr: string; color: string }> = {
  'window-cleaning':  { en: 'Streak-Free',       fr: 'Sans Traces',        color: 'bg-sky-500/35' },
  'gutter-cleaning':  { en: 'Clog Prevention',   fr: 'Anti-Obstruction',   color: 'bg-amber-600/35' },
  'pressure-washing': { en: 'Deep Clean',        fr: 'Nettoyage Intensif', color: 'bg-emerald-600/35' },
  'siding-cleaning':  { en: 'Curb Appeal',       fr: 'Façade Propre',      color: 'bg-violet-600/35' },
  'snow-removal':     { en: 'Winter Ready',      fr: 'Prêt Hiver',         color: 'bg-blue-600/35' },
};
---

<BaseLayout
  title={isFr ? 'All Star Cleaning Ottawa | Nettoyage de Vitres, Gouttières et Lavage sous Pression' : 'All Star Cleaning Ottawa | Window, Gutter & Pressure Washing'}
  description={isFr ? 'Service de nettoyage de confiance à Ottawa. Nettoyage de vitres, gouttières, lavage sous pression, revêtement et déneigement. Devis gratuits.' : "Ottawa's trusted cleaning service. Window cleaning, gutter cleaning, pressure washing, siding cleaning & snow removal. Free quotes: residential & commercial."}
  locale={locale}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/` }]}
  schema={[howtoSchema, homeBreadcrumbSchema]}
>
  <!-- ============================================================ -->
  <!-- HERO SECTION — Full-screen bg image + centered overlay (SHINE layout) -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Accueil' : 'Homepage hero'} class="relative flex min-h-[85vh] items-center justify-center overflow-hidden md:min-h-screen pt-4 sm:pt-10">
    <!-- Background image with dark blue overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src={cms.heroImage}
        alt="All Star Cleaning — sparkling clean Ottawa home"
        role="presentation"
        width="1344"
        height="768"
        class="h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-midnight-indigo-dark/95 via-midnight-indigo-dark/80 to-midnight-indigo-dark/95"></div>
    </div>

    <!-- Centered hero content -->
    <div class="relative z-10 mx-auto max-w-5xl px-4 py-10 text-center sm:px-6 sm:py-16">
      <img src="/images/logo.png" alt="All Star Cleaning" width="180" height="60" class="slide-up mx-auto mb-8 h-20 w-auto sm:h-24 brightness-0 invert object-contain" />
      <h1 class="slide-up font-heading text-3xl font-extrabold uppercase tracking-tight text-text-on-dark sm:text-5xl md:text-6xl lg:text-8xl">
        {isFr ? cms.heroHeadlineFr : cms.heroHeadlineEn}
      </h1>
      <p class="fade-in delay-2 mx-auto mt-6 max-w-2xl text-lg font-medium text-text-on-dark-muted sm:text-xl md:text-2xl">
        {isFr ? cms.heroSubtitleFr : cms.heroSubtitleEn}
      </p>
      
      <div class="fade-in delay-4 mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={`/${locale}/contact`} class="touch-target group inline-flex w-full items-center justify-center gap-3 rounded-full bg-white px-10 py-4 text-lg font-bold uppercase tracking-wider text-midnight-indigo shadow-2xl transition-all hover:bg-white/90 hover:scale-105 active:scale-95 sm:w-auto">
          {isFr ? 'Obtenez un Devis' : 'Get a Quote'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <!-- Trust badges (Stacked Layout for visual balance) -->
      <div class="fade-in delay-5 mt-12 flex flex-col items-center gap-3">
        <!-- Top Row: Uniform sizing -->
        <div class="flex flex-wrap items-center justify-center gap-3">
          <!-- Free Estimates -->
          <div class="flex min-w-[150px] items-center justify-center gap-2 rounded-full bg-amber-500/10 px-4 py-2.5 backdrop-blur-md border border-amber-500/20">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
            <span class="text-[10px] font-bold uppercase tracking-widest text-text-on-dark sm:text-xs">{isFr ? 'Devis Gratuits' : 'Free Estimates'}</span>
          </div>

          <!-- Google Rating -->
          <a 
            href={siteSettings.googleUrl} 
            target="_blank" 
            rel="noopener noreferrer" 
            class="flex min-w-[150px] items-center justify-center gap-2 rounded-full bg-white/10 px-4 py-2.5 backdrop-blur-md border border-white/20 transition-all hover:bg-white/20 hover:scale-105 active:scale-95"
            aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c3.11 0 5.72-1.03 7.63-2.77l-3.57-2.77c-1.01.68-2.31 1.09-4.06 1.09-3.13 0-5.78-2.11-6.73-4.96H2.62v2.87C4.52 20.38 8.04 23 12 23z" fill="#34A853"/><path d="M5.27 13.59c-.24-.71-.38-1.47-.38-2.27 0-.79.14-1.55.38-2.26V6.19H2.62C1.81 7.82 1.35 9.66 1.35 11.62c0 1.96.46 3.8 1.27 5.43l2.65-2.07z" fill="#FBBC05"/><path d="M12 4.39c1.7 0 3.22.58 4.42 1.73l3.31-3.31C17.71 1.05 15.09 0 12 0 8.04 0 4.52 2.62 2.62 6.19l3.3 2.57C6.88 6.5 9.53 4.39 12 4.39z" fill="#EA4335"/></svg>
            <div class="flex text-yellow-400">
              {[...Array(5)].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 sm:h-3.5 sm:w-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="text-xs font-bold text-text-on-dark">{cms.googleRating}</span>
          </a>
        </div>

        <!-- Bottom Row: Primary Trust -->
        <div class="flex min-w-[200px] items-center justify-center gap-2 rounded-full bg-emerald-500/10 px-6 py-2.5 backdrop-blur-md border border-emerald-500/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="text-[10px] font-bold uppercase tracking-widest text-text-on-dark sm:text-xs">{isFr ? 'Assuré & Cautionné' : 'Insured & Bonded'}</span>
        </div>
      </div>
    </div>

    <!-- Bottom scroll indicator -->
    <div class="absolute bottom-4 left-1/2 -translate-x-1/2 animate-bounce opacity-30">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-text-on-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 13 5 5 5-5"/><path d="m7 6 5 5 5-5"/></svg>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- USP SECTION — Image + feature cards split layout -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Pourquoi nous choisir' : 'Why choose us'} class="relative z-0 bg-card pt-16 pb-8 md:pt-20 md:pb-10 lg:pt-24 lg:pb-12">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <!-- Decorative blue accent line -->
      <div class="mb-10 h-px w-full bg-midnight-indigo/20 md:mb-12"></div>

      <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 items-center">
        <!-- Left column: Image of team at work -->
        <div class="fade-in relative z-0 order-2 lg:order-1">
          <div class="overflow-hidden rounded-2xl shadow-lg">
            <img
              src={cms.teamImage}
              alt={isFr ? "L'équipe All Star Cleaning au travail à Ottawa" : 'All Star Cleaning crew at work in Ottawa'}
              width="1344"
              height="768"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
          <!-- Floating badge overlay -->
          <div class="absolute -bottom-4 -right-2 sm:right-4 flex items-center gap-2 rounded-xl bg-midnight-indigo px-4 py-3 shadow-xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-text-on-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            <span class="text-sm font-bold text-text-on-dark">{isFr ? 'Assuré & Cautionné' : 'Insured & Bonded'}</span>
          </div>
        </div>

        <!-- Right column: Text + feature cards -->
        <div class="order-1 lg:order-2">
          <h2 class="heading-section slide-up font-heading font-bold text-midnight-indigo">
            {isFr ? 'Pourquoi Choisir All Star?' : 'Why Choose All Star?'}
          </h2>
          <p class="fade-in delay-2 mt-4 measure text-lg text-muted-foreground">
            {isFr
              ? "Expertise locale, équipement de qualité professionnelle et une garantie de satisfaction sans tracas: c'est ce qui nous distingue à Ottawa."
              : 'Local expertise, professional-grade equipment, and a hassle-free satisfaction guarantee: that\'s what sets us apart in Ottawa.'}
          </p>

          <!-- Feature cards stacked -->
          <div class="mt-8 flex flex-col gap-4">
            {usps.map((usp, i) => (
              <div class:list={[
                'fade-in rounded-xl border p-5 flex items-start gap-4 transition-all duration-300 hover:shadow-md',
                usp.icon === 'shield' ? 'bg-emerald-subtle border-green-500/20' : 
                usp.icon === 'sparkles' ? 'bg-sky-subtle border-sky-500/20' : 
                'bg-amber-subtle border-amber-500/20'
              ]}>
                <div class:list={[
                  'flex h-10 w-10 shrink-0 items-center justify-center rounded-full',
                  usp.icon === 'shield' ? 'bg-green-500/10 text-green-600' : 
                  usp.icon === 'sparkles' ? 'bg-sky-500/10 text-sky-600' : 
                  'bg-amber-500/10 text-amber-600'
                ]}>
                  {usp.icon === 'shield' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  )}
                  {usp.icon === 'sparkles' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                  )}
                  {usp.icon === 'check-circle' && (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  )}
                </div>
                <div>
                  <h3 class:list={[
                    'font-heading text-base font-semibold',
                    usp.icon === 'shield' ? 'text-green-800' : 
                    usp.icon === 'sparkles' ? 'text-sky-800' : 
                    'text-amber-800'
                  ]}>{usp.title}</h3>
                  <p class="mt-1 measure text-base leading-relaxed text-muted-foreground">{usp.description}</p>
                </div>
              </div>
            ))}
          </div>

          <a href={`/${locale}/contact`} class="group fade-in delay-3 mt-8 inline-flex items-center gap-2 text-sm font-semibold text-midnight-indigo transition-colors hover:text-midnight-indigo-dark">
            {isFr ? 'Obtenez votre devis gratuit' : 'Get your free quote'}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- SERVICES SECTION — Varied grid with featured first card -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Nos services' : 'Our services'} class="bg-white pt-8 pb-16 md:pt-10 md:pb-20 lg:pt-12 lg:pb-24">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <div class="text-center">
        <h2 class="heading-subsection slide-up font-heading font-bold text-midnight-indigo">{isFr ? 'Nos Services' : 'Our Services'}</h2>
        <p class="fade-in delay-2 mx-auto mt-4 max-w-2xl measure text-muted-foreground">{isFr ? "Des fenêtres étincelantes aux allées déneigées, nous couvrons tout Ottawa." : "From sparkling windows to snow-free driveways, we've got Ottawa covered."}</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => {
          const imgSrc = service.image || `/images/${service.slug}.jpg`;
          const isFeatured = i === 0;
          const features = isFr ? service.frFeatures : service.features;
          return (
            <a
              href={`/${locale}/services/${service.slug}`}
              class:list={[
                'group relative overflow-hidden rounded-2xl transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl',
                isFeatured
                  ? 'md:col-span-2 lg:col-span-2 aspect-[4/3] md:aspect-[16/9] lg:aspect-[8/3]'
                  : i === 1
                  ? 'aspect-[4/3] lg:aspect-auto'
                  : 'aspect-[4/3]',
              ]}
            >
              {/* Full-bleed image */}
              <img
                src={imgSrc}
                alt={isFr ? service.frName : service.name}
                width="800"
                height="600"
                class:list={['absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105', serviceObjectPosition[service.slug] ?? 'object-center']}
                loading={i < 2 ? 'eager' : 'lazy'}
              />

              {/* Gradient overlay — higher indigo wash for maximum text safety */}
              <div class="absolute inset-0 bg-gradient-to-t from-midnight-indigo-dark/98 via-midnight-indigo-dark/80 to-transparent" />

              {/* Content anchored to bottom */}
              <div class="absolute bottom-0 left-0 right-0 flex flex-col gap-2 p-4 md:p-5">
                {/* Badges row */}
                {(() => {
                  const badge = serviceBadgeMap[service.slug];
                  return (
                    <div class="flex flex-wrap gap-1.5">
                      <span class:list={['w-fit rounded-md px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-text-on-dark backdrop-blur-sm', badge?.color ?? 'bg-midnight-indigo/35']}>
                        {badge ? (isFr ? badge.fr : badge.en) : service.name}
                      </span>
                    </div>
                  );
                })()}

                <h3 class:list={['font-heading font-bold text-text-on-dark drop-shadow', isFeatured ? 'text-2xl lg:text-3xl' : 'text-xl']}>
                  {isFr ? service.frName : service.name}
                </h3>
                <p class="line-clamp-2 text-sm leading-relaxed text-text-on-dark-muted">
                  {isFr ? service.frDescription : service.description}
                </p>
                {features?.length > 0 && (
                  <ul class="space-y-1">
                    {features.slice(0, isFeatured ? 3 : 2).map((feature: string) => (
                      <li class="flex items-center gap-2 text-xs text-text-on-dark-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 text-text-on-dark/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                        <span>{feature}</span>
                      </li>
                    ))}
                  </ul>
                )}

                {/* Frosted glass CTA */}
                <div class:list={[
                  'mt-1 flex w-fit items-center gap-2 rounded-xl border border-white/30 py-1.5 pl-3 pr-1.5 backdrop-blur-md transition-all duration-300 group-hover:bg-white/25',
                  serviceBadgeMap[service.slug]?.color?.replace('bg-', 'bg-').replace('/35', '/15') || 'bg-white/15'
                ]}>
                  <span class="text-xs font-semibold text-text-on-dark">
                    {isFr ? 'En savoir plus' : 'Learn more'}
                  </span>
                  <div class="flex h-5 w-5 shrink-0 items-center justify-center rounded-lg border border-white/30 transition-transform duration-300 group-hover:translate-x-0.5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-text-on-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TRUST / STATS SECTION — 3 trust pillars in a row -->
  <!-- ============================================================ -->
  <section class="bg-midnight-indigo py-10 text-text-on-dark md:py-14" aria-label={isFr ? 'Preuve de confiance' : 'Trust indicators'}>
    <div class="mx-auto max-w-5xl px-4">
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-3 sm:gap-8">
        <!-- 5-star rating -->
        <div class="text-center">
          <div class="text-text-on-dark/90 text-2xl" aria-label="5 out of 5 stars"><svg xmlns="http://www.w3.org/2000/svg" class="inline h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div>
          <p class="mt-2 text-2xl font-bold">5/5</p>
          <p class="text-sm text-text-on-dark-muted">{cms.googleReviewCount} {isFr ? cms.statsRatingFr : cms.statsRatingEn}</p>
        </div>
        <!-- Free Estimates -->
        <div class="text-center">
          <div class="text-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-8 w-8 text-text-on-dark/90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <p class="mt-2 text-2xl font-bold uppercase">{isFr ? 'Gratuit' : 'Free'}</p>
          <p class="text-sm text-text-on-dark-muted">{isFr ? 'Estimations Gratuites' : 'Free Estimates'}</p>
        </div>
        <!-- 7 days/week -->
        <div class="text-center">
          <div class="text-2xl">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-8 w-8 text-text-on-dark/90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <p class="mt-2 text-2xl font-bold">7 <span class="text-base">{isFr ? 'jours' : 'days'}</span></p>
          <p class="text-sm text-text-on-dark-muted">{isFr ? 'Ouvert chaque semaine' : 'Open every day of the week'}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- HOW IT WORKS SECTION — 3-step process with before/after image -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Comment ça marche' : 'How it works'} class="py-16 md:py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 md:px-6">
      <div class="text-center">
        <h2 class="heading-subsection slide-up font-heading text-3xl font-bold text-midnight-indigo sm:text-4xl">{isFr ? 'Comment Ça Marche' : 'How It Works'}</h2>
        <p class="fade-in delay-2 mx-auto mt-4 max-w-2xl measure text-muted-foreground">{isFr ? "Obtenez un extérieur impeccable en trois étapes simples. C'est aussi facile que ça." : 'Get a spotless exterior in three simple steps. It\'s that easy.'}</p>
      </div>

      <!-- 3-step process -->
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        <!-- Step 1 -->
        <div class="fade-in text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-sky-500/10 text-sky-600 border-2 border-sky-500/20">
            <span class="font-heading text-3xl font-bold">1</span>
          </div>
          <h3 class="mt-5 font-heading text-lg font-semibold text-sky-900">{isFr ? 'Demandez un Devis' : 'Request a Quote'}</h3>
          <p class="mt-2 measure text-base text-muted-foreground">{isFr ? "Appelez-nous ou remplissez notre formulaire en ligne. Nous vous répondons sous 24 heures avec un devis gratuit et sans engagement." : 'Call us or fill out our online form. We respond within 24 hours with a free, no-obligation quote.'}</p>
        </div>
        <!-- Step 2 -->
        <div class="fade-in delay-1 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-midnight-indigo/10 text-midnight-indigo border-2 border-midnight-indigo/20">
            <span class="font-heading text-3xl font-bold">2</span>
          </div>
          <h3 class="mt-5 font-heading text-lg font-semibold text-midnight-indigo">{isFr ? 'Nous Faisons le Travail' : 'We Do the Work'}</h3>
          <p class="mt-2 measure text-base text-muted-foreground">{isFr ? "Notre équipe professionnelle arrive à l'heure, utilise un équipement de qualité et traite votre maison avec soin. Aucun dégât, aucun désordre." : 'Our professional crew arrives on time, uses premium equipment, and treats your home with care. No damage, no mess.'}</p>
        </div>
        <!-- Step 3 -->
        <div class="fade-in delay-2 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-600 border-2 border-emerald-500/20">
            <span class="font-heading text-3xl font-bold">3</span>
          </div>
          <h3 class="mt-5 font-heading text-lg font-semibold text-emerald-900">{isFr ? 'Appréciez le Résultat' : 'Enjoy the Result'}</h3>
          <p class="mt-2 measure text-base text-muted-foreground">{isFr ? "Vitres étincelantes, gouttières propres, allées comme neuves. Et si vous n'êtes pas satisfait à 100%, nous revenons sans frais." : 'Sparkling windows, clean gutters, driveways like new. And if you\'re not 100% satisfied, we come back at no charge.'}</p>
        </div>
      </div>

      <!-- Before/After image -->
      <div class="fade-in delay-3 mt-14 overflow-hidden rounded-2xl shadow-lg">
        <img
          src={cms.beforeAfterImage}
          alt={isFr ? 'Résultats avant et après le nettoyage extérieur' : 'Before and after exterior cleaning results'}
          width="1344"
          height="768"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- CTA SECTION — Background image with overlay, gold CTA -->
  <!-- ============================================================ -->
  <section aria-label={isFr ? 'Appel à l\'action' : 'Call to action'} class="relative overflow-hidden py-20 text-text-on-dark md:py-24 lg:py-28">
    <!-- Background image with overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src={cms.ctaImage}
        alt="Clean home exterior ready for service"
        role="presentation"
        width="1344"
        height="768"
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-midnight-indigo-dark/90"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10 mx-auto max-w-4xl px-4 md:px-6 text-center">
      <h2 class="heading-subsection slide-up font-heading text-3xl font-bold !text-text-on-dark md:text-4xl">{isFr ? cms.ctaHeadlineFr : cms.ctaHeadlineEn}</h2>
      <p class="fade-in delay-2 mx-auto mt-4 max-w-2xl text-text-on-dark-muted">{isFr ? cms.ctaSubtitleFr : cms.ctaSubtitleEn}</p>
      <div class="fade-in delay-4 mt-8 flex flex-col items-center gap-4 md:flex-row md:justify-center">
        <a href={`/${locale}/contact`} class="touch-target inline-flex items-center rounded-full bg-midnight-indigo px-8 py-3.5 text-lg font-semibold uppercase tracking-wider text-text-on-dark shadow-lg transition-all hover:bg-midnight-indigo-dark hover:shadow-xl">
          {t.cta.freeQuote}
        </a>
        <a href={`tel:${cms.phoneLink}`} class="touch-target inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-3.5 text-lg font-semibold uppercase tracking-wider text-text-on-dark transition-all hover:border-white/60 hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {cms.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
