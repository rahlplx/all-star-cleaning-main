---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const web3formsKey = import.meta.env.WEB3FORMS_ACCESS_KEY ?? '';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Contact', frLabel: 'Contact', href: `/${locale}/contact` },
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa',
  url: `https://allstarcleaning.ca/${locale}/contact/`,
  mainEntity: {
    '@type': 'HomeAndConstructionBusiness',
    name: 'All Star Cleaning',
    telephone: '+1-613-314-3300',
    email: 'hello@allstarcleaning.ca',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '800 Hunt Club Rd',
      addressLocality: 'Ottawa',
      addressRegion: 'ON',
      postalCode: 'K1V 1C3',
      addressCountry: 'CA',
    },
  },
};
---
<PageLayout
  title={isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa'}
  description={isFr ? 'Contactez All Star Cleaning pour un devis gratuit. Appelez le (613) 314-3300 ou remplissez notre formulaire en ligne.' : 'Contact All Star Cleaning for a free quote. Call (613) 314-3300 or fill out our online form.'}
  locale={locale}
  breadcrumbs={breadcrumbs}
  schema={[contactPageSchema, breadcrumbSchema]}
  heroTitle={isFr ? 'Contactez-Nous' : 'Contact Us'}
  heroSubtitle={isFr ? "Obtenez un devis gratuit pour tous vos besoins en nettoyage extérieur" : 'Get a free quote for all your exterior cleaning needs'}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/contact/` }]}
>
  <section class="py-8 sm:py-12">
    <div class="mx-auto max-w-5xl px-4">
      <div class="grid gap-10 lg:grid-cols-5">
        <!-- Contact Form (appears first on mobile for conversion) -->
        <div class="rounded-xl border border-border bg-card p-6 order-first lg:order-none md:col-span-3 lg:col-span-3">
          <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Demande de Devis Gratuit' : 'Request a Free Quote'}</h2>
          <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Remplissez le formulaire ci-dessous et nous vous répondrons rapidement.' : "Fill out the form below and we'll get back to you quickly."}</p>

          <form id="contact-form" class="mt-6 space-y-4" novalidate>
            <input type="hidden" name="access_key" value={web3formsKey} />
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-navy">{isFr ? 'Nom' : 'Name'} <span class="text-destructive" aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" required autocomplete="name" aria-describedby="name-hint" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-3 text-base text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20" placeholder={isFr ? 'Votre nom' : 'Your name'} />
                <p id="name-hint" class="sr-only">{isFr ? 'Le nom est requis' : 'Name is required'}</p>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-navy">{isFr ? 'Téléphone' : 'Phone'} <span class="text-destructive" aria-hidden="true">*</span></label>
                <input type="tel" id="phone" name="phone" required autocomplete="tel" aria-describedby="phone-hint" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-3 text-base text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20" placeholder={isFr ? '(613) 000-0000' : '(613) 000-0000'} />
                <p id="phone-hint" class="sr-only">{isFr ? 'Le numéro de téléphone est requis' : 'Phone number is required'}</p>
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy">{isFr ? 'Courriel' : 'Email'}</label>
              <input type="email" id="email" name="email" autocomplete="email" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-3 text-base text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20" placeholder={isFr ? 'votre@courriel.ca' : 'your@email.ca'} />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-navy">{isFr ? 'Service souhaité' : 'Service Needed'}</label>
              <select id="service" name="service" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-3 text-base text-navy transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20">
                <option value="">{isFr ? 'Sélectionnez un service' : 'Select a service'}</option>
                <option value="window-cleaning">{isFr ? 'Nettoyage de Vitres' : 'Window Cleaning'}</option>
                <option value="gutter-cleaning">{isFr ? 'Nettoyage de Gouttières' : 'Gutter Cleaning'}</option>
                <option value="pressure-washing">{isFr ? 'Lavage sous Pression' : 'Pressure Washing'}</option>
                <option value="siding-cleaning">{isFr ? 'Nettoyage de Revêtement' : 'Siding Cleaning'}</option>
                <option value="snow-removal">{isFr ? 'Dénéigement' : 'Snow Removal'}</option>
                <option value="other">{isFr ? 'Autre' : 'Other'}</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy">{isFr ? 'Message' : 'Message'}</label>
              <textarea id="message" name="message" rows="4" class="mt-1 block w-full rounded-md border border-border bg-card px-4 py-3 text-base text-navy placeholder:text-muted-foreground transition-colors focus:border-teal-text focus:outline-none focus:ring-2 focus:ring-teal-text/20 resize-y" placeholder={isFr ? 'Décrivez vos besoins en nettoyage...' : 'Describe your cleaning needs...'}></textarea>
            </div>
            <!-- Honeypot field for spam protection (Web3Forms) -->
            <input type="text" name="botcheck" style="display:none" aria-hidden="true" tabindex="-1" autocomplete="off" />
            <button type="submit" class="w-full rounded-lg uppercase tracking-wider bg-gold px-6 py-4 text-lg font-bold text-navy transition-all hover:bg-gold-light hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold active:scale-[0.98] touch-target">
              {isFr ? 'Obtenez Mon Devis Gratuit' : 'Get My Free Quote'}
            </button>
            <p class="text-center text-xs text-muted-foreground">{isFr ? 'Aucun spam · Nous répondons sous 24 heures' : 'No spam · We respond within 24 hours'}</p>
          </form>
          <div id="form-success" role="alert" aria-live="polite" class="hidden rounded-lg bg-green/10 border border-green/20 p-4 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-8 w-8 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <p class="mt-2 font-semibold text-navy">{isFr ? 'Demande envoyée !' : 'Request sent!'}</p>
            <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Nous vous répondrons dans les plus brefs délais.' : "We'll get back to you shortly."}</p>
          </div>
          <div id="form-error" role="alert" aria-live="assertive" class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-8 w-8 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="mt-2 font-semibold text-navy">{isFr ? 'Erreur lors de l\'envoi' : 'Submission failed'}</p>
            <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Une erreur s\'est produite. Veuillez réessayer ou nous appeler au (613) 314-3300.' : 'Something went wrong. Please try again or call us at (613) 314-3300.'}</p>
          </div>
        </div>

        <!-- Contact Info (appears second on mobile) -->
        <div class="space-y-6 md:col-span-2 lg:col-span-2">
          <!-- Trust Badge -->
          <div class="rounded-xl bg-teal-text p-5 text-text-on-dark">
            <div class="flex items-center gap-3">
              <span class="text-gold-light text-lg" aria-label="5 out of 5 stars"><svg xmlns="http://www.w3.org/2000/svg" class="inline h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
              <div>
                <p class="text-sm font-bold">5/5 {isFr ? 'note parfaite' : 'perfect rating'}</p>
                <p class="text-xs text-text-on-dark-muted">{isFr ? '16 avis Google vérifiés' : '16 verified Google reviews'}</p>
              </div>
            </div>
            <p class="mt-2 text-sm text-text-on-dark-muted">{isFr ? 'Satisfaction garantie à 100% · Assuré & Cautionné' : '100% satisfaction guaranteed · Insured & Bonded'}</p>
          </div>

          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Appelez-Nous' : 'Call Us'}</h2>
            <a href="tel:+16133143300" class="mt-2 inline-flex items-center gap-2 text-lg font-medium text-teal-text hover:text-teal-dark touch-target transition-colors">(613) 314-3300</a>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Courriel' : 'Email'}</h2>
            <a href="mailto:hello@allstarcleaning.ca" class="mt-2 inline-flex items-center gap-2 text-lg font-medium text-teal-text hover:text-teal-dark touch-target transition-colors">hello@allstarcleaning.ca</a>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Adresse' : 'Address'}</h2>
            <p class="mt-2 text-muted-foreground">{t.contact.address}</p>
          </div>
          <div>
            <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Heures' : 'Hours'}</h2>
            <p class="mt-2 text-muted-foreground">{t.contact.hours}</p>
          </div>

          <!-- Google Map -->
          <div class="rounded-xl border border-border overflow-hidden">
            <iframe
              src="https://www.google.com/maps?q=800+Hunt+Club+Rd+Ottawa+ON+K1V+1C3&z=15&output=embed"
              width="100%"
              height="250"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={isFr ? 'Notre emplacement sur Google Maps' : 'Our location on Google Maps'}
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
<script>
  const isFr = document.documentElement.lang === 'fr';
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const errorAlert = document.getElementById('form-error');

  if (form && success && errorAlert) {
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const btnOriginalText = submitBtn?.textContent?.trim() || '';

    function setLoading(loading: boolean) {
      if (!submitBtn) return;
      submitBtn.disabled = loading;
      if (loading) {
        submitBtn.dataset.originalText = submitBtn.textContent?.trim() || '';
        submitBtn.innerHTML = isFr
          ? '<span class="inline-flex items-center gap-2"><svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Envoi en cours...</span>'
          : '<span class="inline-flex items-center gap-2"><svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Sending...</span>';
      } else {
        submitBtn.textContent = submitBtn.dataset.originalText || btnOriginalText;
      }
    }

    function hideAlerts() {
      success.classList.add('hidden');
      errorAlert.classList.add('hidden');
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideAlerts();

      let isValid = true;
      const requiredFields = form.querySelectorAll('[required]');
      requiredFields.forEach((field) => {
        field.classList.remove('field-error');
        const hint = field.closest('div')?.querySelector('.field-error-message');
        if (hint) hint.remove();
        if (!field.validity.valid) {
          isValid = false;
          field.classList.add('field-error');
          field.setAttribute('aria-invalid', 'true');
          const msg = document.createElement('p');
          msg.className = 'field-error-message';
          msg.setAttribute('role', 'alert');
          msg.textContent = field.validity.valueMissing
            ? (isFr
              ? (field.labels?.[0]?.textContent?.replace(' *', '') + ' est requis')
              : (field.labels?.[0]?.textContent?.replace(' *', '') + ' is required'))
            : field.validationMessage;
          field.closest('div')?.appendChild(msg);
        } else {
          field.removeAttribute('aria-invalid');
        }
      });
      if (!isValid) {
        const firstError = form.querySelector('.field-error');
        (firstError as HTMLElement | null)?.focus();
        return;
      }

      // Honeypot check — if botcheck is filled, silently "succeed" (it's a bot)
      const botcheck = form.querySelector('input[name="botcheck"]') as HTMLInputElement | null;
      if (botcheck && botcheck.value) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
        success.setAttribute('tabindex', '-1');
        success.focus();
        return;
      }

      // Submit to Web3Forms
      setLoading(true);
      try {
        const formData = new FormData(form);
        formData.append('subject', isFr
          ? 'Nouvelle demande de devis — All Star Cleaning'
          : 'New Quote Request — All Star Cleaning');
        formData.append('from_name', formData.get('name') as string || 'Website Visitor');

        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          form.classList.add('hidden');
          success.classList.remove('hidden');
          success.setAttribute('tabindex', '-1');
          success.focus();
        } else {
          errorAlert.classList.remove('hidden');
          errorAlert.setAttribute('tabindex', '-1');
          errorAlert.focus();
        }
      } catch {
        errorAlert.classList.remove('hidden');
        errorAlert.setAttribute('tabindex', '-1');
        errorAlert.focus();
      } finally {
        setLoading(false);
      }
    });

    form.querySelectorAll('[required]').forEach((field) => {
      field.addEventListener('input', () => {
        field.classList.remove('field-error');
        field.removeAttribute('aria-invalid');
        const hint = field.closest('div')?.querySelector('.field-error-message');
        if (hint) hint.remove();
      });
    });
  }
</script>
</PageLayout>
