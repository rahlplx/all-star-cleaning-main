---
import PageLayout from '@/layouts/PageLayout.astro';
import SocialLinks from '@/components/SocialLinks.astro';
import { useTranslations } from '@/i18n/translations';
import { getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const isFr = locale === 'fr';
const t = useTranslations(locale);
const altLocale = isFr ? 'en' : 'fr';
const s = siteSettings;
const web3formsKey = import.meta.env.WEB3FORMS_ACCESS_KEY || '';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Contact', frLabel: 'Contact', href: `/${locale}/contact` },
];

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": isFr ? "Contactez All Star Cleaning" : "Contact All Star Cleaning",
  "description": isFr ? "Contactez All Star Cleaning pour un devis gratuit de nettoyage extérieur à Ottawa." : "Contact All Star Cleaning for a free exterior cleaning quote in Ottawa.",
  "url": `https://allstarcleaning.ca/${locale}/contact/`,
  "mainEntity": {
    "@type": "HomeAndConstructionBusiness",
    "name": "All Star Cleaning",
    "telephone": `+1${s.phoneLink}`,
    "email": s.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": s.addressEn.split(',')[0].trim(),
      "addressLocality": "Ottawa",
      "addressRegion": "ON",
      "postalCode": s.addressEn.match(/[A-Z]\d[A-Z]\s?\d[A-Z]\d/)?.[0] || "K1V 1C3",
      "addressCountry": "CA"
    }
  }
};
---
<PageLayout
  title={isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa'}
  description={isFr ? "Contactez All Star Cleaning pour un devis gratuit de nettoyage extérieur à Ottawa. Vitres, gouttières, lavage sous pression et plus." : "Contact All Star Cleaning for a free exterior cleaning quote in Ottawa. Window cleaning, gutters, pressure washing and more."}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? 'Contactez-Nous' : 'Contact Us'}
  heroSubtitle={isFr ? "Obtenez un devis gratuit — nous répondons en 24 heures" : "Get a free quote — we respond within 24 hours"}
  schema={[breadcrumbSchema, contactPageSchema]}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/contact/` }]}
>
  <section class="py-8 sm:py-12">
    <div class="mx-auto max-w-6xl px-4">
      <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">

        <!-- Left: Contact Form -->
        <div class="fade-in delay-1">
          <h2 class="font-heading heading-card font-bold text-midnight-indigo">{isFr ? 'Obtenez Votre Devis Gratuit' : 'Request Your Free Quote'}</h2>
          <p class="mt-2 text-muted-foreground">{isFr ? 'Remplissez le formulaire ci-dessous et nous vous répondrons dans les 24 heures.' : 'Fill out the form below and we\'ll get back to you within 24 hours.'}</p>

          <form
            id="contact-form"
            action="https://api.web3forms.com/submit"
            method="POST"
            class="mt-8 space-y-6"
          >
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value={isFr ? 'Nouvelle demande de devis — All Star Cleaning' : 'New Quote Request — All Star Cleaning'} />
            <input type="hidden" name="from_name" value="All Star Cleaning Website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none" />

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
              <label for="name" class="block text-sm font-medium text-navy">{isFr ? 'Nom complet' : 'Full Name'} *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                aria-required="true"
                autocomplete="name"
                  aria-describedby="name-error"
                  class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy placeholder-muted-foreground/60 transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  placeholder={isFr ? 'Jean Tremblay' : 'John Smith'}
                />
                <span id="name-error" class="hidden text-xs text-red-600 mt-1" role="alert"></span>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-navy">{isFr ? 'Courriel' : 'Email'} *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  aria-required="true"
                  inputmode="email"
                  autocomplete="email"
                  aria-describedby="email-error"
                  class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy placeholder-muted-foreground/60 transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  placeholder={isFr ? 'jean@exemple.com' : 'john@example.com'}
                />
                <span id="email-error" class="hidden text-xs text-red-600 mt-1" role="alert"></span>
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="phone" class="block text-sm font-medium text-navy">{isFr ? 'Téléphone' : 'Phone'}</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  inputmode="tel"
                  autocomplete="tel"
                  class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy placeholder-muted-foreground/60 transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  placeholder="(613) 555-0123"
                />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-navy">{isFr ? 'Service souhaité' : 'Service Needed'} *</label>
                <select
                  id="service"
                  name="service"
                  required
                  aria-required="true"
                  aria-describedby="service-error"
                  class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                >
                  <option value="">{isFr ? '— Sélectionnez un service —' : '— Select a service —'}</option>
                  <option value="window-cleaning">{isFr ? 'Nettoyage de vitres' : 'Window Cleaning'}</option>
                  <option value="gutter-cleaning">{isFr ? 'Nettoyage de gouttières' : 'Gutter Cleaning'}</option>
                  <option value="pressure-washing">{isFr ? 'Lavage sous pression' : 'Pressure Washing'}</option>
                  <option value="siding-cleaning">{isFr ? 'Nettoyage de revêtement' : 'Siding Cleaning'}</option>
                  <option value="snow-removal">{isFr ? 'Déneigement' : 'Snow Removal'}</option>
                  <option value="other">{isFr ? 'Autre' : 'Other'}</option>
                </select>
                <span id="service-error" class="hidden text-xs text-red-600 mt-1" role="alert"></span>
              </div>
            </div>

            <div>
              <label for="address" class="block text-sm font-medium text-navy">{isFr ? 'Adresse de la propriété' : 'Property Address'}</label>
              <input
                type="text"
                id="address"
                name="address"
                autocomplete="street-address"
                class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy placeholder-muted-foreground/60 transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                placeholder={isFr ? '123 rue Example, Ottawa, ON' : '123 Example St, Ottawa, ON'}
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-navy">{isFr ? 'Décrivez vos besoins' : 'Tell us about your project'} *</label>
              <textarea
                id="message"
                name="message"
                required
                aria-required="true"
                aria-describedby="message-error"
                rows={4}
                class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy placeholder-muted-foreground/60 transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20 resize-y"
                placeholder={isFr ? 'Nombre de fenêtres, hauteur des gouttières, type de surface à laver, etc.' : 'Number of windows, gutter height, surface type to wash, etc.'}
              ></textarea>
              <span id="message-error" class="hidden text-xs text-red-600 mt-1" role="alert"></span>
            </div>

            <div>
              <label for="preferred-date" class="block text-sm font-medium text-navy">{isFr ? 'Date souhaitée' : 'Preferred Date'}</label>
              <input
                type="date"
                id="preferred-date"
                name="preferred_date"
                min={new Date().toISOString().split('T')[0]}
                class="mt-1.5 block w-full rounded-lg border border-border bg-card px-4 py-3 text-navy transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
              />
            </div>

            <div aria-live="polite" id="form-status" class="hidden rounded-lg p-4 text-sm font-medium"></div>

            <button
              type="submit"
              class="touch-target w-full rounded-full bg-midnight-indigo px-8 py-4 text-lg font-bold uppercase tracking-wider text-text-on-dark shadow-lg transition-colors duration-200 hover:bg-midnight-indigo-dark hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo sm:w-auto"
            >
              {isFr ? 'Envoyer la Demande' : 'Send Request'}
            </button>

            <p class="text-xs text-muted-foreground">{isFr ? '* Obligatoire. Nous ne partageons jamais vos renseignements.' : '* Required. We never share your information.'}</p>
          </form>
        </div>

        <!-- Right: Contact Info + Map -->
        <div class="fade-in delay-2 space-y-6">
          <!-- Contact Cards -->
          <div class="space-y-4">
            <!-- Phone -->
            <a
              href={`tel:${s.phoneLink}`}
              class="touch-target flex items-center gap-4 rounded-xl border border-border bg-card p-5 transition-colors duration-200 hover:bg-midnight-indigo/5 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo"
            >
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-muted-foreground">{isFr ? 'Téléphone' : 'Phone'}</p>
                <p class="text-lg font-bold text-navy">{s.phone}</p>
              </div>
            </a>

            <!-- Email -->
            <a
              href={`mailto:${s.email}`}
              class="touch-target flex items-center gap-4 rounded-xl border border-border bg-card p-5 transition-colors duration-200 hover:bg-midnight-indigo/5 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo"
            >
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-muted-foreground">{isFr ? 'Courriel' : 'Email'}</p>
                <p class="text-lg font-bold text-navy">{s.email}</p>
              </div>
            </a>

            <!-- Address -->
            <div class="flex items-center gap-4 rounded-xl border border-border bg-card p-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-muted-foreground">{isFr ? 'Adresse' : 'Address'}</p>
                <p class="text-lg font-bold text-navy">{isFr ? s.addressFr : s.addressEn}</p>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex items-center gap-4 rounded-xl border border-border bg-card p-5">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-muted-foreground">{isFr ? 'Heures d\'ouverture' : 'Hours'}</p>
                <p class="text-lg font-bold text-navy">{isFr ? s.hoursFr : s.hoursEn}</p>
              </div>
            </div>
          </div>

          <!-- Google Map -->
          <div class="overflow-hidden rounded-xl border border-border shadow-sm">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2800.5!2d-75.6667!3d45.35!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDXCsDIxJzAwLjAiTiA3NcKwNDAnMDAuMSJX!5e0!3m2!1sen!2sca!4v1"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={isFr ? 'Emplacement de All Star Cleaning sur Google Maps' : 'All Star Cleaning location on Google Maps'}
              class="h-[300px] w-full"
            ></iframe>
          </div>

          <!-- Social Links -->
          <div class="rounded-xl border border-border bg-card p-5">
            <h3 class="font-heading text-lg font-bold text-navy">{t.ui.followUs}</h3>
            <div class="mt-3">
              <SocialLinks variant="light" locale={locale} />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section aria-label={isFr ? 'Appel à l\'action' : 'Call to action'} class="relative overflow-hidden py-16 text-text-on-dark md:py-20">
    <div class="absolute inset-0 z-0 bg-midnight-indigo-dark"></div>
    <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
      <h2 class="font-heading text-3xl font-bold text-text-on-dark md:text-4xl">{isFr ? 'Prêt à Commencer?' : 'Ready to Get Started?'}</h2>
      <p class="mx-auto mt-4 max-w-2xl text-text-on-dark-muted">{isFr ? 'Appelez-nous directement ou remplissez le formulaire ci-dessus. Nous sommes ouverts 7 jours par semaine!' : 'Call us directly or fill out the form above. We\'re open 7 days a week!'}</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={`tel:${s.phoneLink}`} class="touch-target inline-flex items-center gap-2 rounded-full bg-text-on-dark px-8 py-3.5 text-lg font-bold uppercase tracking-wider text-midnight-indigo shadow-lg transition-colors duration-200 hover:bg-text-on-dark/90 hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {s.phone}
        </a>
        <a href={`mailto:${s.email}`} class="touch-target inline-flex items-center gap-2 rounded-full border-2 border-text-on-dark/30 px-8 py-3.5 text-lg font-bold uppercase tracking-wider text-text-on-dark transition-colors duration-200 hover:border-text-on-dark/60 hover:bg-text-on-dark/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {s.email}
        </a>
      </div>
    </div>
  </section>
</PageLayout>
