---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { getBreadcrumbSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const web3formsKey = import.meta.env.WEB3FORMS_ACCESS_KEY ?? '';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Contact', frLabel: 'Contact', href: `/${locale}/contact` },
];
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const contactPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa',
  url: `https://allstarcleaning.ca/${locale}/contact/`,
  mainEntity: {
    '@type': 'HomeAndConstructionBusiness',
    name: 'All Star Cleaning',
    telephone: '+1-613-314-3300',
    email: 'hello@allstarcleaning.ca',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '800 Hunt Club Rd',
      addressLocality: 'Ottawa',
      addressRegion: 'ON',
      postalCode: 'K1V 1C3',
      addressCountry: 'CA',
    },
  },
};
---
<PageLayout
  title={isFr ? 'Contactez-Nous | All Star Cleaning Ottawa' : 'Contact Us | All Star Cleaning Ottawa'}
  description={isFr ? 'Contactez All Star Cleaning pour un devis gratuit. Appelez le (613) 314-3300 ou remplissez notre formulaire en ligne.' : 'Contact All Star Cleaning for a free quote. Call (613) 314-3300 or fill out our online form.'}
  locale={locale}
  breadcrumbs={breadcrumbs}
  schema={[contactPageSchema, breadcrumbSchema]}
  heroTitle={isFr ? 'Contactez-Nous' : 'Contact Us'}
  heroSubtitle={isFr ? "Obtenez un devis gratuit pour tous vos besoins en nettoyage extérieur" : 'Get a free quote for all your exterior cleaning needs'}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/contact/` }]}
>
  <section class="py-16 md:py-20 lg:py-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-5">
        <!-- Contact Form (appears first on mobile for conversion) -->
        <div class="rounded-xl border border-border bg-card p-6 order-first lg:order-none lg:col-span-3">
          <h2 class="font-heading text-xl font-semibold text-navy">{isFr ? 'Demande de Devis Gratuit' : 'Request a Free Quote'}</h2>
          <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Remplissez le formulaire ci-dessous et nous vous répondrons rapidement.' : "Fill out the form below and we'll get back to you quickly."}</p>

          <form id="contact-form" class="mt-6 space-y-4" novalidate>
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" aria-hidden="true" />
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="name" class="mb-1 block text-sm font-medium text-navy">
                  {isFr ? 'Nom complet' : 'Full Name'} <span class="text-destructive" aria-hidden="true">*</span>
                </label>
                <input type="text" id="name" name="name" required autocomplete="name"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-navy transition-colors placeholder:text-muted-foreground focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  placeholder={isFr ? 'Jean Tremblay' : 'John Smith'}
                  aria-describedby="name-error" />
                <p id="name-error" class="mt-1 hidden text-sm text-destructive" role="alert"></p>
              </div>
              <div>
                <label for="email" class="mb-1 block text-sm font-medium text-navy">
                  {isFr ? 'Courriel' : 'Email'} <span class="text-destructive" aria-hidden="true">*</span>
                </label>
                <input type="email" id="email" name="email" required autocomplete="email"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-navy transition-colors placeholder:text-muted-foreground focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  placeholder={isFr ? 'jean@exemple.com' : 'john@example.com'}
                  aria-describedby="email-error" />
                <p id="email-error" class="mt-1 hidden text-sm text-destructive" role="alert"></p>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label for="phone" class="mb-1 block text-sm font-medium text-navy">
                  {isFr ? 'Téléphone' : 'Phone'} <span class="text-destructive" aria-hidden="true">*</span>
                </label>
                <input type="tel" id="phone" name="phone" required autocomplete="tel"
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-navy transition-colors placeholder:text-muted-foreground focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  placeholder={isFr ? '(613) 555-1234' : '(613) 555-1234'}
                  aria-describedby="phone-error" />
                <p id="phone-error" class="mt-1 hidden text-sm text-destructive" role="alert"></p>
              </div>
              <div>
                <label for="service" class="mb-1 block text-sm font-medium text-navy">
                  {isFr ? 'Service souhaité' : 'Service Needed'} <span class="text-destructive" aria-hidden="true">*</span>
                </label>
                <select id="service" name="service" required
                  class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-navy transition-colors focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                  aria-describedby="service-error">
                  <option value="">{isFr ? '-- Sélectionnez un service --' : '-- Select a service --'}</option>
                  <option value="window-cleaning">{isFr ? 'Nettoyage de Vitres' : 'Window Cleaning'}</option>
                  <option value="gutter-cleaning">{isFr ? 'Nettoyage de Gouttières' : 'Gutter Cleaning'}</option>
                  <option value="pressure-washing">{isFr ? 'Lavage sous Pression' : 'Pressure Washing'}</option>
                  <option value="siding-cleaning">{isFr ? 'Nettoyage de Revêtement' : 'Siding Cleaning'}</option>
                  <option value="snow-removal">{isFr ? 'Déneigement' : 'Snow Removal'}</option>
                </select>
                <p id="service-error" class="mt-1 hidden text-sm text-destructive" role="alert"></p>
              </div>
            </div>
            <div>
              <label for="message" class="mb-1 block text-sm font-medium text-navy">
                {isFr ? 'Décrivez votre besoin' : 'Tell us about your project'} <span class="text-destructive" aria-hidden="true">*</span>
              </label>
              <textarea id="message" name="message" required rows="4"
                class="w-full rounded-lg border border-border bg-background px-4 py-2.5 text-navy transition-colors placeholder:text-muted-foreground focus:border-midnight-indigo focus:outline-none focus:ring-2 focus:ring-midnight-indigo/20"
                placeholder={isFr ? 'Nombre de fenêtres, étage, problèmes spécifiques...' : 'Number of windows, stories, specific concerns...'}
                aria-describedby="message-error"></textarea>
              <p id="message-error" class="mt-1 hidden text-sm text-destructive" role="alert"></p>
            </div>
            <button type="submit"
              class="w-full rounded-full bg-midnight-indigo px-6 py-3 text-sm font-bold uppercase tracking-wider text-text-on-dark shadow-lg transition-all duration-200 hover:bg-midnight-indigo-dark hover:shadow-xl focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 active:scale-[0.98]">
              {isFr ? 'Envoyer la Demande' : 'Send Request'}
            </button>
            <p class="text-center text-xs text-muted-foreground">
              {isFr ? 'Nous répondons généralement dans les 2 heures.' : 'We typically respond within 2 hours.'}
            </p>
          </form>
          <div id="form-success" class="hidden rounded-lg border border-green/30 bg-green-surface p-6 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <h3 class="mt-3 font-heading text-lg font-semibold text-navy">{isFr ? 'Demande Envoyée!' : 'Request Sent!'}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Merci! Nous vous contacterons sous peu.' : 'Thank you! We will be in touch shortly.'}</p>
          </div>
        </div>

        <!-- Contact Info Sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <div class="rounded-xl border border-border bg-card p-6">
            <h3 class="font-heading text-lg font-semibold text-navy">{isFr ? 'Contactez-Nous Directement' : 'Reach Us Directly'}</h3>
            <div class="mt-4 space-y-4">
              <a href="tel:+16133143300" class="flex items-center gap-3 text-navy transition-colors hover:text-midnight-indigo">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10 text-midnight-indigo" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                <div>
                  <p class="text-sm font-medium">{isFr ? 'Téléphone' : 'Phone'}</p>
                  <p class="text-sm text-muted-foreground">(613) 314-3300</p>
                </div>
              </a>
              <a href="mailto:hello@allstarcleaning.ca" class="flex items-center gap-3 text-navy transition-colors hover:text-midnight-indigo">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10 text-midnight-indigo" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </span>
                <div>
                  <p class="text-sm font-medium">{isFr ? 'Courriel' : 'Email'}</p>
                  <p class="text-sm text-muted-foreground">hello@allstarcleaning.ca</p>
                </div>
              </a>
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10 text-midnight-indigo" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <div>
                  <p class="text-sm font-medium">{isFr ? 'Adresse' : 'Address'}</p>
                  <p class="text-sm text-muted-foreground">800 Hunt Club Rd, Ottawa, ON K1V 1C3</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-midnight-indigo/10 text-midnight-indigo" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </span>
                <div>
                  <p class="text-sm font-medium">{isFr ? 'Heures' : 'Hours'}</p>
                  <p class="text-sm text-muted-foreground">{isFr ? 'Lundi-Dimanche: 9h-19h' : 'Mon-Sun: 9am-7pm'}</p>
                </div>
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-midnight-indigo/10 bg-midnight-indigo-surface p-6">
            <h3 class="font-heading text-lg font-semibold text-navy">{isFr ? 'Urgence? Appelez-nous!' : 'Emergency? Call us!'}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{isFr ? 'Branche-banche tombée ou dégât d\'eau? Nous sommes disponibles 7j/7.' : 'Fallen branch or water damage? We are available 7 days a week.'}</p>
            <a href="tel:+16133143300" class="mt-4 inline-flex items-center gap-2 rounded-full bg-midnight-indigo px-5 py-2.5 text-sm font-bold text-text-on-dark transition-all hover:bg-midnight-indigo-dark">
              {isFr ? 'Appelez le (613) 314-3300' : 'Call (613) 314-3300'}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successDiv = document.getElementById('form-success');

  const fields: Record<string, { el: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement; errorEl: HTMLElement; validate: (v: string) => string | null }> = {};

  function init() {
    const nameEl = document.getElementById('name') as HTMLInputElement;
    const emailEl = document.getElementById('email') as HTMLInputElement;
    const phoneEl = document.getElementById('phone') as HTMLInputElement;
    const serviceEl = document.getElementById('service') as HTMLSelectElement;
    const messageEl = document.getElementById('message') as HTMLTextAreaElement;

    fields.name = { el: nameEl, errorEl: document.getElementById('name-error')!, validate: (v) => !v.trim() ? (document.documentElement.lang === 'fr' ? 'Veuillez entrer votre nom.' : 'Please enter your name.') : null };
    fields.email = { el: emailEl, errorEl: document.getElementById('email-error')!, validate: (v) => { if (!v.trim()) return document.documentElement.lang === 'fr' ? 'Veuillez entrer votre courriel.' : 'Please enter your email.'; if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return document.documentElement.lang === 'fr' ? 'Veuillez entrer un courriel valide.' : 'Please enter a valid email address.'; return null; } };
    fields.phone = { el: phoneEl, errorEl: document.getElementById('phone-error')!, validate: (v) => !v.trim() ? (document.documentElement.lang === 'fr' ? 'Veuillez entrer votre numéro de téléphone.' : 'Please enter your phone number.') : null };
    fields.service = { el: serviceEl, errorEl: document.getElementById('service-error')!, validate: (v) => !v ? (document.documentElement.lang === 'fr' ? 'Veuillez sélectionner un service.' : 'Please select a service.') : null };
    fields.message = { el: messageEl, errorEl: document.getElementById('message-error')!, validate: (v) => !v.trim() ? (document.documentElement.lang === 'fr' ? 'Veuillez décrire votre projet.' : 'Please describe your project.') : null };

    Object.values(fields).forEach(({ el, errorEl }) => {
      el.addEventListener('blur', () => validateField(el.name));
      el.addEventListener('input', () => { if (errorEl.textContent) validateField(el.name); });
    });

    form.addEventListener('submit', handleSubmit);
  }

  function validateField(name: string): boolean {
    const field = fields[name];
    if (!field) return true;
    const error = field.validate(field.el.value);
    if (error) {
      field.errorEl.textContent = error;
      field.errorEl.classList.remove('hidden');
      field.el.setAttribute('aria-invalid', 'true');
      return false;
    } else {
      field.errorEl.textContent = '';
      field.errorEl.classList.add('hidden');
      field.el.removeAttribute('aria-invalid');
      return true;
    }
  }

  function validateAll(): boolean {
    let valid = true;
    Object.keys(fields).forEach((name) => { if (!validateField(name)) valid = false; });
    return valid;
  }

  async function handleSubmit(e: Event) {
    e.preventDefault();
    if (!validateAll()) { fields[Object.keys(fields).find((n) => fields[n].el.getAttribute('aria-invalid') === 'true') || 'name']?.el.focus(); return; }
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.textContent || '';
    submitBtn.disabled = true;
    submitBtn.textContent = document.documentElement.lang === 'fr' ? 'Envoi...' : 'Sending...';
    try {
      const formData = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
      const result = await response.json();
      if (result.success) { form.classList.add('hidden'); successDiv?.classList.remove('hidden'); }
      else { alert(document.documentElement.lang === 'fr' ? 'Une erreur est survenue. Veuillez réessayer.' : 'Something went wrong. Please try again.'); }
    } catch { alert(document.documentElement.lang === 'fr' ? 'Une erreur est survenue. Veuillez réessayer.' : 'Something went wrong. Please try again.'); }
    finally { submitBtn.disabled = false; submitBtn.textContent = originalText; }
  }

  init();
</script>
