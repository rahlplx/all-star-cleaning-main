---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { services } from '@/data/services';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}

const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';

const mainPages = [
  { label: t.nav.home, href: `/${locale}` },
  { label: t.nav.about, href: `/${locale}/about` },
  { label: t.nav.reviews, href: `/${locale}/reviews` },
  { label: t.nav.contact, href: `/${locale}/contact` },
];

const legalPages = [
  { label: t.footer.privacy, href: `/${locale}/privacy` },
  { label: t.footer.terms, href: `/${locale}/terms` },
];
---

<BaseLayout
  title={isFr ? "Plan du Site | All Star Cleaning" : 'Sitemap | All Star Cleaning'}
  description={isFr ? "Plan du site de All Star Cleaning Ottawa. Trouvez tous nos services et pages." : 'Sitemap for All Star Cleaning Ottawa. Find all our services and pages.'}
  locale={locale}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/sitemap/` }]}
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="slide-up font-heading heading-section font-bold text-royal-blue">{isFr ? 'Plan du Site' : 'Sitemap'}</h1>
      
      <div class="mt-12 grid gap-12 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Main Pages -->
        <div>
          <h2 class="mb-4 font-heading heading-subsection font-semibold text-navy">{isFr ? 'Pages Principales' : 'Main Pages'}</h2>
          <ul class="space-y-2">
            {mainPages.map((page) => (
              <li>
                <a href={page.href} class="text-muted-foreground hover:text-royal-blue transition-colors">
                  {page.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Services -->
        <div>
          <h2 class="mb-4 font-heading heading-subsection font-semibold text-navy">{t.nav.services}</h2>
          <ul class="space-y-2">
            {services.map((service) => (
              <li>
                <a href={`/${locale}/services/${service.slug}`} class="text-muted-foreground hover:text-royal-blue transition-colors">
                  {isFr ? service.frName : service.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h2 class="mb-4 font-heading heading-subsection font-semibold text-navy">{isFr ? 'Légal' : 'Legal'}</h2>
          <ul class="space-y-2">
            {legalPages.map((page) => (
              <li>
                <a href={page.href} class="text-muted-foreground hover:text-royal-blue transition-colors">
                  {page.label}
                </a>
              </li>
            ))}
            <li>
              <a href="/sitemap-index.xml" class="text-muted-foreground hover:text-royal-blue transition-colors">
                XML Sitemap Index
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
