---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { getReviewSchema, getBreadcrumbSchema } from '@/seo';
import type { ReviewData } from '@/seo';
import type { BreadcrumbItem } from '@/types';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Reviews', frLabel: 'Témoignages', href: `/${locale}/reviews` },
];

const aggregateRatingSchema = {
  "@type": "AggregateRating",
  "itemReviewed": { "@type": "LocalBusiness", "name": "All Star Cleaning Ottawa" },
  "ratingValue": "5",
  "bestRating": "5",
  "ratingCount": "16",
};

const reviewData: ReviewData[] = isFr ? [
  {
    author: 'Marie Tremblay',
    rating: 5,
    text: "Service exceptionnel ! Ils ont nettoyé nos gouttières et fenêtres en une seule visite. L'équipe était ponctuelle, professionnelle et a tout laissé impeccable. Nous les engageons chaque saison maintenant.",
    service: 'Nettoyage de Gouttières',
    date: '2026-02-15',
  },
  {
    author: 'Jean-Pierre Beaulieu',
    rating: 5,
    text: "Le lavage sous pression a redonné vie à notre entrée : on dirait qu'elle est neuve ! Résultats impressionnants et prix très raisonnable. Je recommande fortement All Star Cleaning.",
    service: 'Lavage sous Pression',
    date: '2026-01-20',
  },
  {
    author: 'Sophie Lafontaine',
    rating: 5,
    text: "Nos fenêtres n'ont jamais été aussi propres. L'équipe a utilisé le système à eau pure et le résultat est éblouissant, même au soleil. Aucune trace, aucun dommage. Service cinq étoiles !",
    service: 'Nettoyage de Vitres',
    date: '2025-12-10',
  },
  {
    author: 'Marc Dupuis',
    rating: 4,
    text: "Excellent service de déneigement cet hiver. Réponse rapide lors des tempêtes et always à l'heure. Le seul petit bémol est qu'ils sont parfois difficiles à joindre les jours de forte demande, mais la qualité est au rendez-vous.",
    service: 'Déneigement',
    date: '2025-11-05',
  },
  {
    author: 'Isabelle Roux',
    rating: 5,
    text: "Nous avons fait nettoyer le revêtement de notre maison : quelle transformation ! La technique de lavage doux a éliminé toutes les taches de moisissure sans abîmer le vinyle. Résultat spectaculaire.",
    service: 'Nettoyage de Revêtement',
    date: '2025-10-18',
  },
] : [
  {
    author: 'Sarah Mitchell',
    rating: 5,
    text: "Outstanding service! They cleaned our gutters and windows in a single visit. The crew was on time, professional, and left everything spotless. We've booked them for every season now.",
    service: 'Gutter Cleaning',
    date: '2026-02-15',
  },
  {
    author: 'David Chen',
    rating: 5,
    text: "The pressure washing brought our driveway back to life: it looks brand new! Impressive results and very reasonable pricing. I highly recommend All Star Cleaning.",
    service: 'Pressure Washing',
    date: '2026-01-20',
  },
  {
    author: 'Emily Watson',
    rating: 5,
    text: "Our windows have never been this clean. The team used a pure water-fed pole system and the result is dazzling, even in direct sunlight. No streaks, no damage. Five-star service!",
    service: 'Window Cleaning',
    date: '2025-12-10',
  },
  {
    author: 'Robert Patel',
    rating: 4,
    text: "Great snow removal service this winter. Fast response during storms and always on time. The only minor issue is they can be hard to reach on peak demand days, but the quality is always excellent.",
    service: 'Snow Removal',
    date: '2025-11-05',
  },
  {
    author: 'Jennifer Adams',
    rating: 5,
    text: "We had our siding cleaned and what a transformation! The soft-wash technique removed all the mold stains without damaging the vinyl. Spectacular results: our home looks years newer.",
    service: 'Siding Cleaning',
    date: '2025-10-18',
  },
];

const reviewSchemas = getReviewSchema(reviewData, locale);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
---
<PageLayout
  title={isFr ? 'Témoignages | All Star Cleaning Ottawa' : 'Reviews | All Star Cleaning Ottawa'}
  description={isFr ? "Lisez les témoignages de nos clients satisfaits à Ottawa. Note parfaite de 5/5 sur Google." : 'Read reviews from our satisfied Ottawa customers. Perfect 5/5 rating on Google.'}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? 'Témoignages' : 'Customer Reviews'}
  heroSubtitle={isFr ? 'Découvrez pourquoi nos clients nous donnent 5/5 sur Google' : 'See why our customers give us a perfect 5/5 on Google'}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/reviews/` }]}
  schema={[...reviewSchemas, aggregateRatingSchema, breadcrumbSchema]}
>
  <section class="py-4 sm:py-8">
    <div class="mx-auto max-w-5xl px-4">
      <!-- Trust summary bar -->
      <div class="slide-up rounded-xl bg-teal-text px-6 py-4 text-text-on-dark">
        <div class="flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <div class="flex items-center gap-3">
            <!-- 5 gold stars in the summary -->
            <div class="flex gap-0.5" aria-label="5 out of 5 stars">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold-light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold-light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold-light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold-light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold-light" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <span class="text-lg font-semibold">{isFr ? '5/5, note parfaite' : '5/5 perfect rating'}</span>
          </div>
            <span class="text-sm text-text-on-dark-muted">{isFr ? 'Basé sur 16 avis Google' : 'From 16 Google reviews'}</span>
        </div>
      </div>

      <h1 class="sr-only">{isFr ? 'Témoignages' : 'Customer Reviews'}</h1>

      <!-- Review cards -->
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reviewData.map((review, i) => {
          const delayClass = `delay-${Math.min(i + 1, 5)}`;
          return (
            <div class={`fade-in ${delayClass} hover-lift rounded-xl border border-border bg-card p-6`}>
              <!-- Star rating -->
              <div class="flex gap-0.5" aria-label={`${review.rating} out of 5 stars`}>
                {Array.from({ length: 5 }).map((_, starIdx) => (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class={`h-4 w-4 ${starIdx < review.rating ? 'text-gold-dark' : 'text-border'}`}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <!-- Review text — left-aligned for readability -->
              <p class="mt-4 text-base text-muted-foreground leading-relaxed">{review.text}</p>
              <!-- Reviewer info -->
              <div class="mt-4 border-t border-border pt-4">
                <p class="text-sm font-semibold text-navy">{review.author}</p>
                <p class="text-xs text-muted-foreground">{review.service} · {review.date}</p>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Google Reviews link — primary filled button -->
      <div class="mt-12 text-center">
        <a
          href="https://g.page/allstarcleaningottawa"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-teal-text px-8 py-3.5 text-lg font-semibold text-text-on-dark transition-all hover:bg-teal-dark hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-text touch-target external-link"
          aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          {isFr ? 'Voir nos avis Google' : 'See our Google Reviews'}
        </a>
      </div>
      <!-- CTA after reviews -->
      <div class="mt-10 rounded-xl bg-navy px-6 py-8 text-center text-text-on-dark sm:px-10">
        <h2 class="font-heading text-2xl font-bold">{isFr ? 'Prêt à obtenir un devis?' : 'Ready to Get a Quote?'}</h2>
        <p class="mt-2 text-text-on-dark-muted">{isFr ? "Rejoignez nos clients satisfaits. Devis gratuit, sans engagement." : 'Join our satisfied customers. Free quotes, no obligation.'}</p>
        <div class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <a href={`/${locale}/contact`} class="touch-target inline-flex items-center rounded-full bg-gold px-8 py-3 text-lg font-semibold uppercase tracking-wider text-navy shadow-lg transition-all hover:bg-gold-light hover:shadow-xl">
            {isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}
          </a>
          <a href="tel:+16133143300" class="touch-target inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-3 text-lg font-semibold uppercase tracking-wider text-text-on-dark transition-all hover:border-white/60 hover:bg-white/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (613) 314-3300
          </a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
