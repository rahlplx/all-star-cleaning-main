---
import PageLayout from '@/layouts/PageLayout.astro';
import { useTranslations } from '@/i18n/translations';
import { getReviewSchema, getBreadcrumbSchema } from '@/seo';
import type { ReviewData } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import homepageData from '@/content/homepage.json';
import siteSettings from '@/content/settings.json';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const t = useTranslations(locale);
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const home = homepageData;
const s = siteSettings;

// Load all reviews from CMS content files
const reviewFiles = import.meta.glob<{ default: Record<string, unknown> }>('/src/content/reviews/*.json', { eager: true });
const allReviews = Object.values(reviewFiles).map((m) => m.default as {
  author: string; rating: number; service: string; frService: string;
  date: string; textEn: string; textFr: string;
});

// Sort newest first
allReviews.sort((a, b) => b.date.localeCompare(a.date));

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Reviews', frLabel: 'Témoignages', href: `/${locale}/reviews` },
];

const reviewData: ReviewData[] = allReviews.map((r) => ({
  author: r.author,
  rating: r.rating,
  text: isFr ? r.textFr : r.textEn,
  service: isFr ? r.frService : r.service,
  date: r.date,
}));

const reviewSchemas = getReviewSchema(reviewData, locale);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
---
<PageLayout
  title={isFr ? 'Témoignages | All Star Cleaning Ottawa' : 'Reviews | All Star Cleaning Ottawa'}
  description={isFr ? "Lisez les témoignages de nos clients satisfaits à Ottawa. Note parfaite de 5/5 sur Google." : 'Read reviews from our satisfied Ottawa customers. Perfect 5/5 rating on Google.'}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? 'Témoignages' : 'Customer Reviews'}
  heroSubtitle={isFr ? 'Découvrez pourquoi nos clients nous donnent 5/5 sur Google' : 'See why our customers give us a perfect 5/5 on Google'}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/reviews/` }]}
  schema={[...reviewSchemas, breadcrumbSchema]}
>
  <section class="py-16 md:py-20 lg:py-28">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <!-- Trust summary bar -->
      <a 
        href={s.googleUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="slide-up block rounded-xl bg-midnight-indigo px-6 py-4 text-white transition-all hover:bg-midnight-indigo-dark hover:scale-[1.01] active:scale-[0.99] group"
        aria-label={isFr ? `${home.googleRating} · Basé sur ${home.googleReviewCount} avis Google (ouvre une nouvelle fenêtre)` : `${home.googleRating} · From ${home.googleReviewCount} Google reviews (opens in new window)`}
      >
        <div class="flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
          <div class="flex items-center gap-3">
            <div class="flex gap-0.5" role="img" aria-label="5 out of 5 stars">
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white/90 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <span class="text-lg font-semibold">{isFr ? `${home.googleRating}, note parfaite` : `${home.googleRating} perfect rating`}</span>
          </div>
          <span class="text-sm text-text-on-dark-muted group-hover:text-white transition-colors">
            {isFr ? `Basé sur ${home.googleReviewCount} avis Google` : `From ${home.googleReviewCount} Google reviews`}
          </span>
        </div>
      </a>

      <!-- Review cards -->
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {reviewData.map((review, i) => {
          const delayClass = `delay-${Math.min(i + 1, 5)}`;
          return (
            <div class={`fade-in ${delayClass} hover-lift rounded-xl border border-border bg-card p-6`}>
              <div class="flex gap-0.5" aria-label={`${review.rating} out of 5 stars`}>
                {Array.from({ length: 5 }).map((_, starIdx) => (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class={`h-4 w-4 ${starIdx < review.rating ? 'text-gold-dark' : 'text-border'}`}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                ))}
              </div>
              <p class="mt-4 text-base text-muted-foreground leading-relaxed">{review.text}</p>
              <div class="mt-4 border-t border-border pt-4">
                <p class="text-sm font-semibold text-navy">{review.author}</p>
                <p class="text-xs text-muted-foreground">{review.service} · {review.date}</p>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Google Reviews link -->
      <div class="mt-12 text-center">
        <a
          href={s.googleUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-midnight-indigo px-8 py-3.5 text-lg font-semibold text-white transition-all hover:bg-midnight-indigo-dark hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-midnight-indigo touch-target external-link"
          aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          {isFr ? 'Voir nos avis Google' : 'See our Google Reviews'}
        </a>
      </div>
    </div>
  </section>

  <!-- CTA SECTION — Premium full-width version synced from homepage -->
  <section aria-label={isFr ? 'Appel à l\'action' : 'Call to action'} class="relative overflow-hidden py-20 text-text-on-dark md:py-24 lg:py-28">
    <!-- Background image with overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src={home.ctaImage}
        alt=""
        role="presentation"
        width="1344"
        height="768"
        class="h-full w-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-midnight-indigo-dark/90"></div>
    </div>
    <!-- Content -->
    <div class="relative z-10 mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h2 class="heading-subsection slide-up font-heading text-3xl font-bold !text-text-on-dark md:text-4xl">{isFr ? home.ctaHeadlineFr : home.ctaHeadlineEn}</h2>
      <p class="fade-in delay-2 mx-auto mt-4 max-w-2xl text-text-on-dark-muted">{isFr ? home.ctaSubtitleFr : home.ctaSubtitleEn}</p>
      <div class="fade-in delay-4 mt-8 flex flex-col items-center gap-4 md:flex-row md:justify-center">
        <a href={`/${locale}/contact`} class="touch-target inline-flex items-center rounded-full bg-midnight-indigo px-8 py-3.5 text-lg font-semibold uppercase tracking-wider text-text-on-dark shadow-lg transition-all hover:bg-midnight-indigo-dark hover:shadow-xl">
          {t.cta.freeQuote}
        </a>
        <a href={`tel:${s.phoneLink}`} class="touch-target inline-flex items-center gap-2 rounded-full border-2 border-white/30 px-8 py-3.5 text-lg font-semibold uppercase tracking-wider text-text-on-dark transition-all hover:border-white/60 hover:bg-white/10">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {s.phone}
        </a>
      </div>
    </div>
  </section>
</PageLayout>
