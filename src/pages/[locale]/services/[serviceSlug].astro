---
import PageLayout from '@/layouts/PageLayout.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import { services } from '@/data/services';
import { getServiceSchema, getBreadcrumbSchema, getFAQSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import siteSettings from '@/content/settings.json';
import homepageData from '@/content/homepage.json';

export function getStaticPaths() {
  return ['en', 'fr'].flatMap((locale) =>
    services.map((service) => ({
      params: { locale, serviceSlug: service.slug },
      props: { service, locale: locale as 'en' | 'fr' },
    }))
  );
}

const { service, locale } = Astro.props;
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: 'Services', frLabel: 'Services', href: `/${locale}/services` },
  { label: service.name, frLabel: service.frName, href: `/${locale}/services/${service.slug}` },
];
const serviceSchema = getServiceSchema(service, locale, `https://allstarcleaning.ca/${locale}/services/${service.slug}`);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const faqSchema = service.faqs && service.faqs.length > 0 ? getFAQSchema(service.faqs, locale) : null;
const allSchemas = [serviceSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];
const altSlug = service.slug;  // Both locales use EN slugs in URLs

const otherServices = services.filter((s) => s.slug !== service.slug);
const responseTimeText = service.slug === 'snow-removal'
  ? (isFr ? 'Sans engagement · Réponse sous 4h lors des tempêtes' : 'No obligation · Response within 4 hours during storms')
  : (isFr ? 'Sans engagement · Réponse sous 24h' : 'No obligation · 24hr response');
---

<PageLayout
  title={isFr ? service.frMetaTitle : service.metaTitle}
  description={isFr ? service.frMetaDescription : service.metaDescription}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={isFr ? service.frName : service.name}
  heroSubtitle={isFr ? service.frDescription : service.description}
  ogImage={service.image ? `https://allstarcleaning.ca${service.image}` : undefined}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/services/${altSlug}/` }]}
  schema={allSchemas}
>
  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <!-- Review Badge -->
      <div class="mb-6 flex flex-wrap items-center gap-3">
        <a 
          href={siteSettings.googleUrl} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="touch-target flex items-center gap-2 rounded-full bg-midnight-indigo/10 px-4 py-3 border border-midnight-indigo/20 transition-transform hover:scale-105 active:scale-95 focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2"
          aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
        >
          <span class="text-midnight-indigo text-sm" role="img" aria-label="5 out of 5 stars"><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
          <span class="text-sm font-bold text-navy">{homepageData.googleRating}</span>
          <span class="text-xs text-muted-foreground">{isFr ? `${siteSettings.googleReviewCount} avis Google` : `${siteSettings.googleReviewCount} Google reviews`}</span>
        </a>
        <div class="touch-target flex items-center gap-2 rounded-full bg-midnight-indigo/10 px-4 py-2 border border-midnight-indigo/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="text-sm font-semibold text-navy">{isFr ? 'Assuré & Cautionné' : 'Insured & Bonded'}</span>
        </div>
      </div>
      <h2 class="font-heading heading-card font-bold text-midnight-indigo">{isFr ? 'Ce qui est inclus' : "What's Included"}</h2>
      <ul class="mt-4 space-y-3">
        {(isFr ? service.frFeatures : service.features).map((feature) => (
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-midnight-indigo" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span class="text-foreground">{feature}</span>
          </li>
        ))}
      </ul>
      <!-- Mobile-only inline CTA -->
      <div class="mt-6 lg:hidden">
        <a href={`/${locale}/contact?service=${service.slug}`} class="touch-target inline-flex items-center gap-2 rounded-full uppercase tracking-wider bg-midnight-indigo px-6 py-4 text-base font-bold text-text-on-dark shadow-lg transition-colors duration-200 hover:bg-midnight-indigo-dark focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 active:scale-[0.98] w-full justify-center">
          {isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <p class="mt-2 text-center text-sm text-muted-foreground">{responseTimeText}</p>
      </div>
      <div class="mt-10">
        <h2 class="font-heading heading-card font-bold text-midnight-indigo">{isFr ? 'Pourquoi choisir All Star Cleaning?' : 'Why Choose All Star Cleaning?'}</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-midnight-indigo/20 bg-midnight-indigo/5 p-4 sm:col-span-2"><h3 class="font-medium text-navy">{isFr ? 'Résultats Garantis' : 'Guaranteed Results'}</h3><p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Satisfaction garantie à 100% sur chaque travail.' : '100% satisfaction guaranteed on every job.'}</p></div>
          <div class="rounded-xl border border-border bg-card p-4"><h3 class="font-medium text-navy">{isFr ? 'Équipement Professionnel' : 'Professional Equipment'}</h3><p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Technologie éprouvée pour des résultats constants.' : 'Proven technology for consistent results.'}</p></div>
          <div class="rounded-xl border border-border bg-card p-4"><h3 class="font-medium text-navy">{isFr ? 'Équipe Expérimentée' : 'Experienced Team'}</h3><p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Techniciens formés et assurés.' : 'Trained and insured technicians.'}</p></div>
          <div class="rounded-xl border border-border bg-card p-4"><h3 class="font-medium text-navy">{isFr ? 'Devis Gratuit' : 'Free Quotes'}</h3><p class="mt-1 text-sm text-muted-foreground">{isFr ? 'Estimations transparentes sans obligation.' : 'Transparent estimates with no obligation.'}</p></div>
        </div>
      </div>

      <!-- Related Services -->
      <div class="mt-10">
        <h2 class="font-heading heading-card font-bold text-midnight-indigo">
          {isFr ? 'Nos autres services' : 'Our other services'}
        </h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {otherServices.map((otherService, i) => (
            <a href={`/${locale}/services/${otherService.slug}`} class={`touch-target group rounded-xl border border-border bg-card p-4 transition-colors duration-200 hover:border-midnight-indigo/30 focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 hover-lift ${i === 0 ? 'sm:col-span-2 border-midnight-indigo/20 bg-midnight-indigo/5' : ''}`}>
              <h3 class="font-medium text-navy group-hover:text-midnight-indigo">{isFr ? otherService.frName : otherService.name}</h3>
              <p class="mt-1 text-sm text-muted-foreground line-clamp-2">{isFr ? otherService.frDescription : otherService.description}</p>
              <span class="mt-2 inline-flex items-center gap-1 text-sm font-medium text-midnight-indigo">
                {isFr ? 'En savoir plus' : 'Learn more'}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>

      <!-- FAQ Section -->
      <FAQAccordion
        faqs={service.faqs}
        locale={locale}
        title={isFr ? `Questions fréquentes: ${service.frName}` : `Frequently asked questions: ${service.name}`}
      />
    </div>
    <div class="lg:col-span-1">
      <div class="lg:sticky lg:top-24 z-sticky max-h-[calc(100vh-8rem)] overflow-y-auto overscroll-behavior-contain rounded-xl border border-border bg-card p-6">
        <h3 class="font-heading text-xl font-bold text-midnight-indigo">{isFr ? service.frCta : service.cta}</h3>
        <p class="mt-2 text-sm text-muted-foreground">{isFr ? service.frDescription : service.description}</p>
        <a href={`/${locale}/contact?service=${service.slug}`} class="mt-4 block rounded-full uppercase tracking-wider bg-midnight-indigo px-6 py-4 text-center text-base font-bold text-text-on-dark shadow-lg transition-colors duration-200 hover:bg-midnight-indigo-dark focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 active:scale-[0.98] touch-target">{isFr ? 'Obtenez un Devis Gratuit' : 'Get a Free Quote'}</a>
        <p class="mt-2 text-center text-sm text-muted-foreground">{responseTimeText}</p>
        <div class="mt-4 border-t border-border pt-4 text-center text-sm text-muted-foreground">
          <a href={`tel:${siteSettings.phoneLink}`} class="inline-flex items-center gap-2 font-semibold text-midnight-indigo hover:text-midnight-indigo-dark focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 touch-target">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {siteSettings.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</PageLayout>
