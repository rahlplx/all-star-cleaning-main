---
// Service + Location combo page — inverse of area/[location]/[service]
// Generates 5 services × 44 locations × 2 langs = 440 pages
// Route: /en/services/window-cleaning/ottawa/
import PageLayout from '@/layouts/PageLayout.astro';
import ServiceBadge from '@/components/ServiceBadge.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';
import { services } from '@/data/services';
import { locations } from '@/data/locations';
import { getLocationServiceSchema, getBreadcrumbSchema, getFAQSchema } from '@/seo';
import type { BreadcrumbItem } from '@/types';
import siteSettings from '@/content/settings.json';
import homepageData from '@/content/homepage.json';

export function getStaticPaths() {
  return ['en', 'fr'].flatMap((locale) =>
    services.flatMap((service) =>
      locations.map((location) => ({
        params: { locale, serviceSlug: service.slug, locationSlug: location.slug },
        props: { service, location, locale: locale as 'en' | 'fr' },
      }))
    )
  );
}

const { service, location, locale } = Astro.props;
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';

const breadcrumbs: BreadcrumbItem[] = [
  { label: 'Home', frLabel: 'Accueil', href: `/${locale}` },
  { label: service.name, frLabel: service.frName, href: `/${locale}/services/${service.slug}` },
  { label: location.name, frLabel: location.frName, href: `/${locale}/services/${service.slug}/${location.slug}` },
];

const locServiceSchema = getLocationServiceSchema(
  service, location, locale,
  `https://allstarcleaning.ca/${locale}/services/${service.slug}/${location.slug}`
);
const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs, locale);
const faqSchema = service.faqs && service.faqs.length > 0 ? getFAQSchema(service.faqs, locale) : null;
const allSchemas = [locServiceSchema, breadcrumbSchema, ...(faqSchema ? [faqSchema] : [])];

const heroTitle = isFr
  ? `${service.frName} à ${location.frName}`
  : `${service.name} in ${location.name}`;
const heroSubtitle = isFr
  ? `${service.frDescription} Desservant ${location.frName} et les environs d'Ottawa.`
  : `${service.description} Serving ${location.name} and surrounding Ottawa areas.`;
const altSlug = service.slug;  // Both locales use EN slugs in URLs
---

<PageLayout
  title={isFr ? `${service.frName} ${location.frName} Ottawa | All Star Cleaning` : `${service.name} ${location.name} Ottawa | All Star Cleaning`}
  description={isFr
    ? `${service.frName} professionnel à ${location.frName}, Ottawa. Devis gratuit: résidentiel et commercial.`
    : `Professional ${service.name.toLowerCase()} in ${location.name}, Ottawa. Free quote: residential & commercial.`}
  locale={locale}
  breadcrumbs={breadcrumbs}
  heroTitle={heroTitle}
  heroSubtitle={heroSubtitle}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/services/${service.slug}/${location.slug}/` }]}
  schema={allSchemas}
>
  <div class="grid gap-8 lg:grid-cols-3">
    <div class="lg:col-span-2">
      <!-- Review Badge -->
      <div class="mb-6 flex flex-wrap items-center gap-3">
        <a 
          href={siteSettings.googleUrl} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-2 rounded-full bg-midnight-indigo/10 px-4 py-2 border border-midnight-indigo/20 transition-all hover:bg-midnight-indigo/20 hover:scale-105 active:scale-95"
          aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
        >
          <span class="text-midnight-indigo text-sm" aria-label="5 out of 5 stars"><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><svg xmlns="http://www.w3.org/2000/svg" class="inline h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></span>
          <span class="text-sm font-bold text-midnight-indigo">{homepageData.googleRating}</span>
          <span class="text-xs text-muted-foreground">{isFr ? `${homepageData.googleReviewCount} avis Google` : `${homepageData.googleReviewCount} Google Reviews`}</span>
        </a>
      </div>

      <!-- Service Pricing CTA -->
      <div class="mb-8 rounded-xl bg-gradient-to-br from-midnight-indigo/10 to-teal-500/10 p-6 md:p-8">
        <p class="text-lg font-semibold text-midnight-indigo">
          {isFr
            ? `Professional ${service.name.toLowerCase()} in ${location.name}`
            : `Service professionnel de ${service.name.toLowerCase()} à ${location.name}`}
        </p>
        <p class="mt-2 measure text-muted-foreground leading-relaxed">
          {isFr
            ? `Contactez-nous dès aujourd'hui pour un devis gratuit pour le ${service.name.toLowerCase()} dans ${location.name} et les environs.`
            : `Contact us today for a free quote on ${service.name.toLowerCase()} in ${location.name} and surrounding areas.`}
        </p>
        <a 
          href={`/${locale}/contact`}
          class="mt-4 inline-flex items-center gap-2 rounded-lg bg-midnight-indigo px-6 py-3 text-sm font-bold text-white transition-all hover:bg-blue-700 hover:scale-105 active:scale-95"
        >
          {isFr ? 'Obtenir un Devis Gratuit' : 'Get a Free Quote'}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <p class="mt-2 text-center text-sm text-muted-foreground">{isFr ? 'Sans engagement · Réponse sous 24h' : 'No obligation · 24hr response'}</p>
      </div>

      <!-- Area Context -->
      <div class="mt-8 rounded-xl border border-border bg-card p-6">
        <h2 class="font-heading text-2xl font-bold text-midnight-indigo">
          {isFr ? `Service à ${location.frName}` : `Serving ${location.name}`}
        </h2>
        <p class="mt-2 measure text-muted-foreground leading-relaxed">
          {isFr
            ? `Nous sommes fiers de desservir ${location.frName} et les quartiers environnants de la région d'Ottawa. Notre équipe locale connaît bien les besoins uniques des propriétés dans cette zone ${location.area} d'Ottawa.`
            : `We proudly serve ${location.name} and surrounding neighbourhoods in the Ottawa region. Our local team understands the unique needs of properties in this ${location.area} Ottawa zone.`}
        </p>
        {location.neighbours.length > 0 && (
          <div class="mt-4">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-muted-foreground">{isFr ? 'Quartiers avoisinants' : 'Nearby Areas'}</h3>
            <div class="mt-2 flex flex-wrap gap-2">
              {location.neighbours.map((neighbour) => {
                const loc = locations.find((l) => l.slug === neighbour);
                return loc ? (
                  <ServiceBadge label={isFr ? loc.frName : loc.name} href={`/${locale}/area/${loc.slug}/${service.slug}`} variant="teal" />
                ) : null;
              })}
            </div>
          </div>
        )}
      </div>

      <!-- Map for location -->
      <div class="mt-8 rounded-xl border border-border overflow-hidden">
        <iframe
          src={`https://www.google.com/maps?q=${location.coordinates.lat},${location.coordinates.lng}&z=13&output=embed`}
          width="100%"
          height="300"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={isFr ? `Carte de ${location.frName}` : `Map of ${location.name}`}
        ></iframe>
      </div>

      <!-- Other Services in this Area -->
      <div class="mt-8">
        <h2 class="font-heading text-2xl font-bold text-midnight-indigo">
          {isFr ? `Autres services à ${location.frName}` : `Other services in ${location.name}`}
        </h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {services
            .filter((s) => s.slug !== service.slug)
            .map((otherService) => (
              <a
                href={`/${locale}/services/${otherService.slug}/${location.slug}`}
                class="group flex items-center gap-3 rounded-lg border border-border bg-card p-4 transition-all hover:border-teal-500/30 hover:shadow-md hover:-translate-y-0.5"
              >
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-teal-500/10 text-teal-600">
                  {isFr ? otherService.frName.charAt(0) : otherService.name.charAt(0)}
                </div>
                <div>
                  <p class="font-semibold text-midnight-indigo group-hover:text-teal-600 transition-colors">
                    {isFr ? otherService.frName : otherService.name}
                  </p>
                  <p class="text-xs text-muted-foreground">{isFr ? `À ${location.frName}` : `In ${location.name}`}</p>
                </div>
              </a>
            ))}
        </div>
      </div>

      <!-- Other Locations for this Service -->
      <div class="mt-8">
        <h2 class="font-heading text-2xl font-bold text-midnight-indigo">
          {isFr ? `Autres secteurs pour ${service.frName}` : `Other areas for ${service.name}`}
        </h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {locations
            .filter((l) => l.slug !== location.slug)
            .slice(0, 12)
            .map((otherLocation) => (
              <a
                href={`/${locale}/services/${service.slug}/${otherLocation.slug}`}
                class="flex items-center gap-2 rounded-lg border border-border bg-card px-3 py-2 text-sm transition-all hover:border-blue-500/30 hover:text-blue-700 hover:shadow-sm"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span>{isFr ? otherLocation.frName : otherLocation.name}</span>
              </a>
            ))}
        </div>
        <a
          href={`/${locale}/services/${service.slug}`}
          class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-teal-600 hover:text-teal-700 transition-colors"
        >
          {isFr ? `Voir tous les secteurs pour ${service.frName}` : `View all areas for ${service.name}`}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    </div>

    <!-- Sidebar -->
    <aside class="space-y-6 lg:col-span-1">
      <!-- Quick Contact -->
      <div class="rounded-xl bg-gradient-to-br from-midnight-indigo to-blue-800 p-6 text-white">
        <h3 class="font-heading text-lg font-bold">{isFr ? 'Contactez-nous' : 'Contact Us'}</h3>
        <p class="mt-1 text-sm text-white/80">{isFr ? 'Appelez-nous dès aujourd\'hui' : 'Call us today'}</p>
        <a 
          href={`tel:${siteSettings.phone}`}
          class="mt-3 flex items-center gap-2 rounded-lg bg-white/20 px-4 py-2 text-sm font-bold transition-all hover:bg-white/30"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {siteSettings.phone}
        </a>
        <a 
          href={`/${locale}/contact`}
          class="mt-2 block rounded-lg bg-white px-4 py-2 text-center text-sm font-bold text-midnight-indigo transition-all hover:bg-blue-50"
        >
          {isFr ? 'Devis Gratuit' : 'Free Quote'}
        </a>
      </div>

      <!-- Service Quick Links -->
      <div class="rounded-xl border border-border bg-card p-6">
        <h3 class="font-heading text-lg font-bold text-midnight-indigo">{isFr ? 'Nos Services' : 'Our Services'}</h3>
        <nav class="mt-3 space-y-1" aria-label={isFr ? 'Liste des services' : 'Services list'}>
          {services.map((s) => (
            <a
              href={`/${locale}/services/${s.slug}`}
              class={`block rounded-lg px-3 py-2 text-sm transition-colors ${s.slug === service.slug ? 'bg-midnight-indigo/10 font-semibold text-midnight-indigo' : 'text-muted-foreground hover:bg-midnight-indigo/5 hover:text-midnight-indigo'}`}
            >
              {isFr ? s.frName : s.name}
            </a>
          ))}
        </nav>
      </div>

      <!-- Location Quick Links -->
      <div class="rounded-xl border border-border bg-card p-6">
        <h3 class="font-heading text-lg font-bold text-midnight-indigo">{isFr ? 'Quartiers' : 'Neighbourhoods'}</h3>
        <nav class="mt-3 space-y-1" aria-label={isFr ? 'Liste des quartiers' : 'Neighbourhoods list'}>
          {locations
            .filter((l) => l.area === location.area)
            .slice(0, 8)
            .map((l) => (
              <a
                href={`/${locale}/services/${service.slug}/${l.slug}`}
                class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-midnight-indigo/5 hover:text-midnight-indigo"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {isFr ? l.frName : l.name}
              </a>
            ))}
        </nav>
      </div>
    </aside>
  </div>

  <!-- Service FAQs -->
  {service.faqs && service.faqs.length > 0 && (
    <div class="mt-12">
      <h2 class="font-heading text-2xl font-bold text-midnight-indigo">
        {isFr ? 'Questions Fréquentes' : 'Frequently Asked Questions'}
      </h2>
      <div class="mt-4">
        <FAQAccordion faqs={service.faqs} locale={locale} />
      </div>
    </div>
  )}
</PageLayout>
