---
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { locale: 'en' } }, { params: { locale: 'fr' } }];
}
const { locale } = Astro.params as { locale: 'en' | 'fr' };
const isFr = locale === 'fr';
const altLocale = isFr ? 'en' : 'fr';
---
<BaseLayout
  title={isFr ? "Conditions d'Utilisation | All Star Cleaning" : 'Terms of Service | All Star Cleaning'}
  description={isFr ? "Conditions d'utilisation de All Star Cleaning Ottawa." : 'Terms of service for All Star Cleaning Ottawa.'}
  locale={locale}
  noindex={true}
  alternateUrls={[{ locale: altLocale, url: `https://allstarcleaning.ca/${altLocale}/terms/` }]}
>
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="slide-up font-heading heading-section font-bold text-royal-blue">{isFr ? "Conditions d'Utilisation" : 'Terms of Service'}</h1>
      <p class="mt-4 text-sm text-muted-foreground">{isFr ? 'Dernière mise à jour : Avril 2026' : 'Last updated: April 2026'}</p>
      <div class="measure mt-8 space-y-6 text-muted-foreground leading-relaxed">
        <h2 class="font-heading heading-subsection font-semibold text-royal-blue">{isFr ? 'Services' : 'Services'}</h2>
        <p>{isFr ? "All Star Cleaning fournit des services de nettoyage extérieur résidentiel et commercial dans la région d'Ottawa. Tous les services sont soumis à disponibilité et à une entente préalable." : 'All Star Cleaning provides residential and commercial exterior cleaning services in the Ottawa region. All services are subject to availability and prior agreement.'}</p>
        <h2 class="font-heading heading-subsection font-semibold text-royal-blue">{isFr ? 'Garantie' : 'Guarantee'}</h2>
        <p>{isFr ? 'Nous offrons une garantie de satisfaction à 100%. Si vous n\'êtes pas satisfait, nous reviendrons pour corriger le travail sans frais supplémentaires.' : 'We offer a 100% satisfaction guarantee. If you are not satisfied, we will return to correct the work at no additional charge.'}</p>
        <h2 class="font-heading heading-subsection font-semibold text-royal-blue">{isFr ? 'Contact' : 'Contact'}</h2>
        <p>{isFr ? 'Pour toute question, contactez-nous à hello@allstarcleaning.ca ou au (613) 314-3300.' : 'For questions, contact us at hello@allstarcleaning.ca or (613) 314-3300.'}</p>
      </div>
    </div>
  </section>
</BaseLayout>
