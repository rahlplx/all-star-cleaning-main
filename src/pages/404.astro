---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Detect locale from URL path or default to 'en'
const pathname = Astro.url.pathname;
const localeFromUrl = pathname.startsWith('/fr') ? 'fr' : 'en';
const isFr = localeFromUrl === 'fr';
---
<BaseLayout
  title={isFr ? 'Page Introuvable | All Star Cleaning Ottawa' : 'Page Not Found | All Star Cleaning Ottawa'}
  description={isFr ? "La page que vous recherchez n'existe pas." : "The page you're looking for doesn't exist."}
  locale={localeFromUrl}
  noindex={true}
>
  <section class="flex min-h-[60vh] flex-col items-center justify-center px-4 py-24 text-center">
    <!-- Sparkle / broom SVG illustration -->
    <div class="slide-up mb-6 text-teal-text" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <!-- Sparkle icon -->
        <path d="M12 3l1.912 5.813a2 2 0 0 0 1.275 1.275L21 12l-5.813 1.912a2 2 0 0 0-1.275 1.275L12 21l-1.912-5.813a2 2 0 0 0-1.275-1.275L3 12l5.813-1.912a2 2 0 0 0 1.275-1.275L12 3z"/>
        <path d="M5 3v1M1 7h1M5 11v1M9 7h1"/>
      </svg>
    </div>
    <h1 class="slide-up font-heading text-6xl font-bold text-navy">404</h1>
    <p class="slide-up mt-4 text-lg text-muted-foreground">
      {isFr
        ? 'On dirait que cette page est partie se faire nettoyer.'
        : 'Looks like this page went off to get cleaned.'}
    </p>
    <p class="slide-up mt-2 text-muted-foreground">
      {isFr
        ? "La page que vous recherchez n'existe pas ou a été déplacée."
        : "The page you're looking for doesn't exist or has been moved."}
    </p>
    <a
      href={`/${localeFromUrl}`}
      class="slide-up mt-8 inline-flex items-center gap-2 rounded-none uppercase tracking-wider bg-teal-text px-8 py-3.5 text-lg font-semibold text-text-on-dark shadow-lg transition-all hover:bg-teal-dark hover:shadow-xl focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-teal-text touch-target"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      {isFr ? "Retour à l'accueil" : 'Go Home'}
    </a>
    <div class="slide-up mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href={`/${localeFromUrl}/services`} class="rounded-full border border-border px-5 py-3 text-sm font-medium text-muted-foreground transition-colors hover:border-teal-text hover:text-teal-text touch-target">{isFr ? 'Nos Services' : 'Our Services'}</a>
      <a href={`/${localeFromUrl}/contact`} class="rounded-full border border-border px-5 py-3 text-sm font-medium text-muted-foreground transition-colors hover:border-teal-text hover:text-teal-text touch-target">{isFr ? 'Contactez-nous' : 'Contact Us'}</a>
      <a href={`/${localeFromUrl}/reviews`} class="rounded-full border border-border px-5 py-3 text-sm font-medium text-muted-foreground transition-colors hover:border-teal-text hover:text-teal-text touch-target">{isFr ? 'Témoignages' : 'Reviews'}</a>
    </div>
  </section>
</BaseLayout>
