---
import { useTranslations } from '@/i18n/translations';
import siteSettings from '@/content/settings.json';
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const s = siteSettings;
const isFr = locale === 'fr';

// Pre-calculate paths to avoid regex issues in template
const currentPath = Astro.url.pathname;
const enPath = currentPath.replace(/^\/[a-z]{2}/, '/en');
const frPath = currentPath.replace(/^\/[a-z]{2}/, '/fr');
---
<div class="brand-gradient text-text-on-dark" role="complementary" aria-label="Contact information">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 py-1.5 sm:py-2">
    <!-- Left: Hours + Address (desktop) / Hours only (mobile) -->
    <div class="flex items-center gap-3 sm:gap-6 text-xs opacity-90 min-w-0">
      <div class="flex items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span class="truncate font-medium">{isFr ? s.hoursFr : s.hoursEn}</span>
      </div>
      <!-- Address (desktop only) -->
      <div class="hidden lg:flex items-center gap-1.5 border-l border-text-on-dark/20 pl-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <span class="truncate font-medium">{isFr ? s.addressFr : s.addressEn}</span>
      </div>
    </div>

    <!-- Right: Contact links -->
    <div class="flex items-center gap-4 sm:gap-6 text-xs">
      <!-- Phone -->
      <a href={`tel:${t.contact.phoneLink}`} class="group inline-flex items-center gap-1.5 font-bold text-text-on-dark transition-all duration-200 hover:text-text-on-dark/80 focus-visible:ring-2 focus-visible:ring-text-on-dark whitespace-nowrap">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0 transition-transform group-hover:rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span class="hidden sm:inline">{t.contact.phone}</span>
        <span class="sm:hidden">{t.cta.callNow}</span>
      </a>

      <!-- Email (desktop only) -->
      <a href={`mailto:${t.contact.email}`} class="hidden font-medium text-text-on-dark transition-all duration-200 hover:text-text-on-dark/80 focus-visible:ring-2 focus-visible:ring-text-on-dark lg:inline-flex items-center gap-1.5 whitespace-nowrap border-l border-text-on-dark/20 pl-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {t.contact.email}
      </a>

      <!-- Language switcher: Classic Toggle -->
      <div class="flex items-center border-l border-text-on-dark/20 pl-4 sm:pl-6">
        <div class="flex items-center gap-1.5 rounded-full bg-black/20 p-1 border border-text-on-dark/10">
          <a 
            href={enPath} 
            class:list={[
              "rounded-full px-2 py-0.5 text-xs font-bold uppercase transition-all duration-200",
              locale === 'en' ? "bg-text-on-dark text-midnight-indigo shadow-sm" : "text-text-on-dark/60 hover:text-text-on-dark"
            ]}
            aria-current={locale === 'en' ? 'page' : undefined}
          >
            EN
          </a>
          <a 
            href={frPath} 
            class:list={[
              "rounded-full px-2 py-0.5 text-xs font-bold uppercase transition-all duration-200",
              locale === 'fr' ? "bg-text-on-dark text-midnight-indigo shadow-sm" : "text-text-on-dark/60 hover:text-text-on-dark"
            ]}
            aria-current={locale === 'fr' ? 'page' : undefined}
          >
            FR
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
