---
import { useTranslations } from '@/i18n/translations';
import { services } from '@/data/services';
import SocialLinks from '@/components/SocialLinks.astro';
import siteSettings from '@/content/settings.json';
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const s = siteSettings;
const year = new Date().getFullYear();
---
<footer class="brand-gradient text-text-on-dark">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href={`/${locale}`} aria-label={`${s.businessName} — ${locale === 'fr' ? 'Accueil' : 'Home'}`} class="group flex flex-col items-start gap-4 no-underline text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">
          <img 
            src={s.footerLogo || '/images/logo-light.png'} 
            alt={s.businessName} 
            width="120" 
            height="120" 
            class="h-14 w-auto sm:h-20 lg:h-24 object-contain brightness-0 invert transition-transform duration-300 group-hover:scale-105" 
            aria-hidden="true" 
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-text-on-dark-muted">{locale === 'fr' ? s.taglineFr : s.taglineEn}</p>
        <div class="mt-8">
          <SocialLinks variant="dark" locale={locale} />
        </div>
      </div>
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-text-on-dark">{t.nav.services}</h3>
        <ul class="space-y-2">
          {services.map((s) => <li><a href={`/${locale}/services/${s.slug}`} class="touch-target inline-flex items-center text-sm text-text-on-dark-muted transition-colors duration-200 hover:text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">{locale === 'fr' ? s.frName : s.name}</a></li>)}
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-text-on-dark">{t.footer.contactUs}</h3>
        <ul class="space-y-4 text-sm text-text-on-dark-muted">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-4 w-4 shrink-0 text-text-on-dark/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="leading-tight">{locale === 'fr' ? s.addressFr : s.addressEn}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-text-on-dark/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href={`tel:${s.phoneLink}`} class="touch-target inline-flex items-center text-text-on-dark/90 no-underline transition-colors duration-200 hover:text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">{s.phone}</a>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-text-on-dark/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            <a href={`mailto:${s.email}`} class="touch-target inline-flex items-center text-text-on-dark/90 no-underline transition-colors duration-200 hover:text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">{s.email}</a>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-text-on-dark">{t.footer.hours}</h3>
        <p class="text-sm text-text-on-dark/90 leading-relaxed">
          {locale === 'fr' ? s.hoursFr : s.hoursEn}
        </p>
      </div>
    </div>
    <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-white/10 pt-6 text-xs text-text-on-dark-muted sm:flex-row">
      <p>&copy; {year} All Star Cleaning. {t.footer.copyright}</p>
      <p class="text-text-on-dark/50">Built by TrendTok Social</p>
      <div class="flex gap-4">
        <a href={`/${locale}/privacy`} class="touch-target inline-flex items-center text-text-on-dark/80 transition-colors duration-200 hover:text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">{t.footer.privacy}</a>
        <a href={`/${locale}/terms`} class="touch-target inline-flex items-center text-text-on-dark/80 transition-colors duration-200 hover:text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">{t.footer.terms}</a>
        <a href={`/${locale}/sitemap`} class="touch-target inline-flex items-center text-text-on-dark/80 transition-colors duration-200 hover:text-text-on-dark focus-visible:ring-2 focus-visible:ring-text-on-dark">{t.footer.sitemap}</a>
      </div>
    </div>
  </div>
</footer>
