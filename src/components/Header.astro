---
import { useTranslations } from '@/i18n/translations';
import { services } from '@/data/services';
import siteSettings from '@/content/settings.json';
interface Props { locale: 'en' | 'fr'; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const s = siteSettings;
const currentPath = Astro.url.pathname;
const navLinks = [
  { label: t.nav.home, href: `/${locale}` },
  { label: t.nav.services, href: `/${locale}/services`, children: services.map((svc) => ({ label: locale === 'fr' ? svc.frName : svc.name, href: `/${locale}/services/${svc.slug}` })) },
  { label: t.nav.about, href: `/${locale}/about` },
  { label: t.nav.reviews, href: `/${locale}/reviews` },
  { label: t.nav.contact, href: `/${locale}/contact` },
];
---
<header id="main-header" class="sticky top-0 z-50 border-b border-border bg-card/95 backdrop-blur-sm transition-all duration-300">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 py-3">
    <!-- Logo -->
    <a href={`/${locale}`} class="touch-target flex items-center gap-2.5 text-navy no-underline focus-visible:ring-2 focus-visible:ring-royal-blue">
      <img src={s.headerLogo || '/images/logo.png'} alt={s.businessName} width="180" height="60" class="h-12 w-auto sm:h-14 object-contain" />
      {/* <span class="font-heading text-xl font-bold tracking-tight leading-none">{s.businessName.replace(' Cleaning', '')}<span class="text-royal-blue"> Cleaning</span></span> */}
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {navLinks.map((link) => (
        <div class="group relative">
          <a href={link.href} class:list={['touch-target inline-flex items-center gap-1.5 rounded-md px-3 py-2 text-sm font-medium transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-royal-blue', currentPath === link.href ? 'bg-royal-blue/10 text-royal-blue' : 'text-navy hover:bg-off-white-dark hover:text-royal-blue']} aria-haspopup={link.children ? 'true' : undefined} aria-expanded={link.children ? 'false' : undefined} aria-current={currentPath === link.href ? 'page' : undefined}>
            {link.label}
            {link.children && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180 [.group[aria-expanded=true]_&]:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            )}
          </a>
          {link.children && (
            <div class="invisible absolute left-0 top-full z-dropdown mt-1 min-w-[220px] rounded-lg border border-border bg-card py-2 shadow-lg opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
              {link.children.map((child) => <a href={child.href} class="touch-target flex items-center gap-2 px-4 py-2.5 text-sm text-navy transition-colors duration-200 hover:bg-off-white-dark hover:text-royal-blue focus-visible:ring-2 focus-visible:ring-royal-blue focus:bg-off-white-dark focus:text-royal-blue">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-royal-blue/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                {child.label}
              </a>)}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Right side: CTA + Mobile toggle -->
    <div class="flex items-center gap-2 sm:gap-3">
      <a href={`/${locale}/contact`} class="hidden rounded-full bg-royal-blue px-5 py-2 text-sm font-bold uppercase tracking-wider text-white shadow-lg transition-all duration-200 hover:bg-royal-blue-dark hover:shadow-xl focus-visible:ring-2 focus-visible:ring-royal-blue focus-visible:ring-offset-2 lg:inline-flex">{t.nav.getQuote}</a>
      <!-- Phone icon for mobile (quick call) -->
      <a href={`tel:${s.phoneLink}`} class="touch-target inline-flex items-center justify-center rounded-full border border-royal-blue/30 p-2.5 text-royal-blue transition-colors hover:bg-royal-blue/5 lg:hidden min-h-[44px] min-w-[44px]" aria-label="Call us">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
      <button id="mobile-menu-toggle" class="touch-target inline-flex items-center justify-center rounded-md p-2.5 text-navy transition-colors duration-200 hover:bg-off-white-dark focus-visible:ring-2 focus-visible:ring-royal-blue lg:hidden min-h-[44px] min-w-[44px]" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg id="menu-open-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        <svg id="menu-close-icon" xmlns="http://www.w3.org/2000/svg" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden border-t border-border bg-card lg:hidden">
    <nav class="mx-auto max-w-7xl px-4 py-4" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <div>
          {link.children ? (
            <div class="mobile-nav-dropdown">
              <button type="button" class="touch-target flex w-full items-center justify-between rounded-md px-3 py-2.5 text-sm font-medium text-navy transition-colors duration-200 hover:bg-off-white-dark focus-visible:ring-2 focus-visible:ring-royal-blue" aria-expanded="false">
                <span class="hover:text-royal-blue transition-colors">{link.label}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="mobile-dropdown-arrow h-4 w-4 shrink-0 text-muted-foreground transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <div class="mobile-dropdown-content ml-3 pl-3 hidden">
                {link.children.map((child) => <a href={child.href} class="touch-target flex items-center gap-2 px-3 py-2 text-sm text-muted-foreground transition-colors duration-200 hover:text-royal-blue focus-visible:ring-2 focus-visible:ring-royal-blue">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 text-royal-blue/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                  {child.label}
                </a>)}
              </div>
            </div>
          ) : (
            <a href={link.href} class:list={['touch-target block rounded-md px-3 py-2.5 text-sm font-medium transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-royal-blue', currentPath === link.href ? 'bg-royal-blue/10 text-royal-blue' : 'text-navy hover:bg-off-white-dark']} aria-current={currentPath === link.href ? 'page' : undefined}>{link.label}</a>
          )}
        </div>
      ))}
      <div class="mt-4 border-t border-border pt-4">
        <a href={`/${locale}/contact`} class="touch-target block rounded-full bg-royal-blue px-5 py-2.5 text-center text-sm font-bold uppercase tracking-wider text-white shadow-lg transition-all duration-200 hover:bg-royal-blue-dark hover:shadow-xl focus-visible:ring-2 focus-visible:ring-royal-blue focus-visible:ring-offset-2">{t.nav.getQuote}</a>
      </div>
    </nav>
  </div>
</header>
<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  function openMenu() {
    menu?.classList.remove('hidden');
    openIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    const firstLink = menu?.querySelector('a, button');
    firstLink?.focus();
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    openIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    toggle?.focus();
  }

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.contains('hidden');
    if (isHidden) openMenu(); else closeMenu();
  });

  // Close mobile menu on Escape
  menu?.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { closeMenu(); return; }

    // Focus trap
    if (e.key === 'Tab') {
      const focusable = menu?.querySelectorAll<HTMLElement>('a[href], button, [tabindex]:not([tabindex="-1"])');
      if (!focusable || focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
  });

  // Close menu when clicking a link inside it
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on resize to desktop
  const mql = window.matchMedia('(min-width: 1024px)');
  mql.addEventListener('change', (e) => { if (e.matches) closeMenu(); });

  // Mobile dropdown accordion toggle
  menu?.querySelectorAll<HTMLDivElement>('.mobile-nav-dropdown').forEach(dropdown => {
    const btn = dropdown.querySelector('button');
    const content = dropdown.querySelector('.mobile-dropdown-content');
    const arrow = dropdown.querySelector('.mobile-dropdown-arrow');
    if (!btn || !content || !arrow) return;

    // Prevent the <a> inside button from navigating on click (toggle instead)
    const linkInBtn = btn.querySelector('a');
    if (linkInBtn) {
      linkInBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const isExpanded = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
        content.classList.toggle('hidden', isExpanded);
        arrow.classList.toggle('rotate-180', !isExpanded);
      });
    }

    btn.addEventListener('click', (e) => {
      // If click was on the link, already handled above
      if ((e.target as HTMLElement).closest('a')) return;
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
      content.classList.toggle('hidden', isExpanded);
      arrow.classList.toggle('rotate-180', !isExpanded);
    });
  });
</script>
<script>
  // Desktop dropdown aria-expanded toggle + arrow rotation
  document.querySelectorAll<HTMLElement>('.group > a[aria-haspopup="true"]').forEach(trigger => {
    const parent = trigger.closest('.group');
    const dropdown = parent?.querySelector(':scope > div[class*="invisible"]');
    const arrow = trigger.querySelector('svg');

    // Toggle on click for touch/desktop hybrid
    trigger.addEventListener('click', (e) => {
      const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
    });

    // Update aria-expanded when dropdown shows/hides via hover
    parent?.addEventListener('mouseenter', () => {
      trigger.setAttribute('aria-expanded', 'true');
    });
    parent?.addEventListener('mouseleave', () => {
      trigger.setAttribute('aria-expanded', 'false');
    });
    parent?.addEventListener('focusin', () => {
      trigger.setAttribute('aria-expanded', 'true');
    });
    parent?.addEventListener('focusout', () => {
      // Small delay to check if focus moved to dropdown content
      setTimeout(() => {
        if (!parent?.contains(document.activeElement)) {
          trigger.setAttribute('aria-expanded', 'false');
        }
      }, 100);
    });
  });
</script>
<script>
  // Sticky header animation on scroll
  const header = document.getElementById('main-header');
  let isSticky = false;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const threshold = 100;

    if (scrollY > threshold && !isSticky) {
      isSticky = true;
      header?.classList.add('is-sticky');
    } else if (scrollY <= threshold && isSticky) {
      isSticky = false;
      header?.classList.remove('is-sticky');
    }
  }, { passive: true });
</script>

<style>
  header.is-sticky {
    animation: headerSlideDown 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    box-shadow: var(--shadow-md);
    background-color: var(--color-card);
  }

  @keyframes headerSlideDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
