---
import siteSettings from '@/content/settings.json';
import homepageData from '@/content/homepage.json';
interface Props {
  locale: 'en' | 'fr';
  variant?: 'pill' | 'bar' | 'inline';
  asLink?: boolean;
}
const { locale, variant = 'pill', asLink = true } = Astro.props;
const isFr = locale === 'fr';
const s = siteSettings;
const h = homepageData;
const reviewCount = s.googleReviewCount || h.googleReviewCount;
const rating = h.googleRating;
const stars = Array.from({ length: 5 });
---
{asLink ? (
  <a
    href={s.googleUrl}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'touch-target flex items-center gap-2 transition-transform duration-200 hover:scale-105 active:scale-95 focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2',
      variant === 'pill' && 'rounded-full bg-midnight-indigo/10 px-4 py-2.5 border border-midnight-indigo/20',
      variant === 'bar' && 'slide-up block rounded-xl bg-midnight-indigo px-6 py-4 text-text-on-dark hover:bg-midnight-indigo-dark hover:scale-[1.01] active:scale-[0.99] group w-full',
      variant === 'inline' && 'rounded-full bg-midnight-indigo/10 px-4 py-2 border border-midnight-indigo/20',
    ]}
    aria-label={isFr ? 'Voir nos avis Google (ouvre une nouvelle fenêtre)' : 'See our Google Reviews (opens in new window)'}
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c3.11 0 5.72-1.03 7.63-2.77l-3.57-2.77c-1.01.68-2.31 1.09-4.06 1.09-3.13 0-5.78-2.11-6.73-4.96H2.62v2.87C4.52 20.38 8.04 23 12 23z" fill="#34A853"/><path d="M5.27 13.59c-.24-.71-.38-1.47-.38-2.27 0-.79.14-1.55.38-2.26V6.19H2.62C1.81 7.82 1.35 9.66 1.35 11.62c0 1.96.46 3.8 1.27 5.43l2.65-2.07z" fill="#FBBC05"/><path d="M12 4.39c1.7 0 3.22.58 4.42 1.73l3.31-3.31C17.71 1.05 15.09 0 12 0 8.04 0 4.52 2.62 2.62 6.19l3.3 2.57C6.88 6.5 9.53 4.39 12 4.39z" fill="#EA4335"/></svg>
    <div class:list={[
      'flex gap-0.5',
      variant === 'bar' ? 'text-text-on-dark/90' : 'text-midnight-indigo',
    ]} role="img" aria-label="5 out of 5 stars">
      {stars.map(() => (
        <svg xmlns="http://www.w3.org/2000/svg" class:list={[
          'shrink-0',
          variant === 'bar' ? 'h-5 w-5' : variant === 'pill' ? 'h-4 w-4' : 'h-3.5 w-3.5',
        ]} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      ))}
    </div>
    {variant === 'bar' ? (
      <div class="flex flex-col sm:flex-row sm:items-center sm:gap-3 w-full">
        <span class="text-lg font-semibold">{rating}, {isFr ? 'note parfaite' : 'perfect rating'}</span>
        <span class="text-sm text-text-on-dark-muted group-hover:text-text-on-dark transition-colors">
          {isFr ? `Basé sur ${reviewCount} avis Google` : `From ${reviewCount} Google reviews`}
        </span>
      </div>
    ) : (
      <>
        <span class:list={['text-sm font-bold', variant === 'pill' ? 'text-navy' : 'text-midnight-indigo']}>{rating}</span>
        <span class="text-xs text-muted-foreground">{isFr ? `${reviewCount} avis Google` : `${reviewCount} Google reviews`}</span>
      </>
    )}
  </a>
) : (
  <span class:list={[
    'inline-flex items-center gap-2',
    variant === 'pill' && 'rounded-full bg-midnight-indigo/10 px-4 py-2 border border-midnight-indigo/20',
    variant === 'inline' && 'rounded-full bg-midnight-indigo/10 px-4 py-2 border border-midnight-indigo/20',
  ]}>
    <div class="flex gap-0.5 text-midnight-indigo" role="img" aria-label="5 out of 5 stars">
      {stars.map(() => (
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      ))}
    </div>
    <span class="text-sm font-bold text-navy">{rating}</span>
    <span class="text-xs text-muted-foreground">{isFr ? `${reviewCount} avis Google` : `${reviewCount} Google reviews`}</span>
  </span>
)}
