---
interface Props {
  heading: string;
  description: string;
  ctaText: string;
  contactHref: string;
  responseTimeText: string;
  phoneLink: string;
  phone: string;
}
const { heading, description, ctaText, contactHref, responseTimeText, phoneLink, phone } = Astro.props;
---
<div class="lg:sticky lg:top-24 z-sticky max-h-[calc(100vh-8rem)] overflow-y-auto overscroll-behavior-contain rounded-xl border border-border bg-card p-6">
  <h3 class="font-heading text-xl font-bold text-midnight-indigo">{heading}</h3>
  <p class="mt-2 text-sm text-muted-foreground">{description}</p>
  <a href={contactHref} class="mt-4 block rounded-full uppercase tracking-wider bg-midnight-indigo px-6 py-4 text-center text-base font-bold text-text-on-dark shadow-lg transition-colors duration-200 hover:bg-midnight-indigo-dark hover:shadow-xl focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 active:scale-[0.98] touch-target">
    {ctaText}
  </a>
  <p class="mt-2 text-center text-sm text-muted-foreground">{responseTimeText}</p>
  <div class="mt-4 border-t border-border pt-4 text-center text-sm text-muted-foreground">
    <a href={`tel:${phoneLink}`} class="inline-flex items-center gap-2 font-semibold text-midnight-indigo hover:text-midnight-indigo-dark focus-visible:ring-2 focus-visible:ring-midnight-indigo focus-visible:ring-offset-2 touch-target">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      {phone}
    </a>
  </div>
</div>
